---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<Layout
  title="視覺小知識｜YoYo 驗光師專欄｜多焦點鏡片 蔡司鏡片 兒童近視追蹤 高度近視｜能見度視覺中心 × 比泱驗光所 新莊板橋"
  description="能見度視覺中心 YoYo 驗光師分享：多焦點鏡片為什麼會暈、老花一定要配多焦點嗎、為什麼戴眼鏡會頭暈、蔡司鏡片值不值得、兒童近視追蹤完整指南。新莊驗光所推薦、板橋驗光首選。"
>
  <section class="bg-brand-navy text-white py-20 px-4 text-center">
    <h1 class="text-4xl font-bold mb-4">視覺小知識</h1>
    <p class="text-gray-300 text-lg max-w-2xl mx-auto">YoYo 驗光師的第一手視光知識，讓你在配鏡前就已經是半個行家。</p>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-20">
    <div class="space-y-6">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="block border border-gray-200 rounded-2xl p-6 hover:shadow-lg transition-shadow hover:border-brand-navy group">
          {post.data.image && (
            <img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover rounded-xl mb-4" />
          )}
          <div class="flex items-center gap-3 mb-3">
            <span class="bg-brand-light text-brand-navy text-xs font-semibold px-3 py-1 rounded-full">{post.data.tag}</span>
            <span class="text-gray-400 text-sm">{post.data.date}</span>
          </div>
          <h2 class="text-xl font-bold text-brand-navy mb-2 group-hover:text-brand-gold transition-colors">{post.data.title}</h2>
          <p class="text-gray-600 text-sm leading-relaxed">{post.data.excerpt}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
