---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const latest = posts.slice(0, 3);

const tagOrder = ['驗光知識', '鏡片知識', '多焦點鏡片', '老花配鏡', '兒童近視追蹤', '蔡司鏡片', '鏡架鏡框'];
const allTags = [...new Set(posts.map(p => p.data.tag))].sort(
  (a, b) => tagOrder.indexOf(a) - tagOrder.indexOf(b)
);
---
<Layout
  title="視覺小知識｜YoYo 驗光師專欄｜多焦點鏡片 蔡司鏡片 兒童近視追蹤 高度近視｜能見度視覺中心 × 比泱驗光所 新莊板橋"
  description="能見度視覺中心 YoYo 驗光師分享：多焦點鏡片為什麼會暈、老花一定要配多焦點嗎、為什麼戴眼鏡會頭暈、蔡司鏡片值不值得、兒童近視追蹤完整指南。新莊驗光所推薦、板橋驗光首選。"
>
  <!-- Hero -->
  <section class="bg-brand-navy text-white py-20 px-6 text-center">
    <h1 class="font-serif text-white mb-4" style="font-size:clamp(28px,5vw,48px);font-weight:300">視覺小知識</h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto">YoYo 驗光師的第一手視光知識，讓你在配鏡前就已經是半個行家。</p>
  </section>

  <!-- 完整指南入口 -->
  <section class="px-6 md:px-16 py-12 border-b border-brand-ink/8" style="background:#f7f3ec">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-serif text-brand-ink" style="font-size:clamp(18px,2.5vw,26px);font-weight:400">📚 完整指南：一頁講透一個主題</h2>
        <a href="/guide/" class="font-sans text-brand-gold hover:underline" style="font-size:13px">全部指南 →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[
          { href: '/guide/progressive-lens/', tag: '老花・多焦點', title: '多焦點鏡片完整指南' },
          { href: '/guide/children-myopia/', tag: '兒童視力', title: '兒童近視追蹤完整指南' },
          { href: '/guide/high-myopia/', tag: '高度近視', title: '高度近視配鏡完整指南' },
          { href: '/guide/lens-brands/', tag: '鏡片品牌', title: '鏡片品牌選購完整指南' },
          { href: '/guide/digital-eye-strain/', tag: '數位疲勞', title: '螢幕族視覺疲勞完整指南' },
          { href: '/guide/choose-optician/', tag: '在地選購', title: '新北配眼鏡完整指南' },
          { href: '/guide/frames/', tag: '鏡框選購', title: '鏡框選購完整指南' },
          { href: '/guide/optical-basics/', tag: '視光小百科', title: '視光小百科' },
          { href: '/guide/aniseikonia/', tag: '雙眼視覺', title: '不等像完整指南' },
          { href: '/guide/rgp-contact-lens/', tag: '硬式隱形眼鏡', title: 'RGP 硬式隱形眼鏡完整指南' },
        ].map(g => (
          <a href={g.href} class="bg-white border border-brand-gold/30 rounded-2xl px-6 py-5 hover:border-brand-gold transition-colors group">
            <span class="font-sans text-brand-gold font-semibold tracking-widest uppercase block mb-2" style="font-size:10px;letter-spacing:0.16em">{g.tag}</span>
            <span class="font-serif text-brand-navy group-hover:text-brand-gold transition-colors" style="font-size:16px;font-weight:600">{g.title} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 最新資訊 -->
  <section class="px-6 md:px-16 py-16" style="background:#eee8da">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-10">
        <h2 class="font-serif text-brand-ink" style="font-size:clamp(20px,3vw,32px);font-weight:300">最新文章</h2>
        <span class="font-sans text-brand-ink-3" style="font-size:13px">最近更新</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {latest.map(post => (
          <a href={`/blog/${post.slug}`} class="bg-white border border-brand-ink/10 p-6 hover:shadow-md transition-shadow group block">
            <div class="flex items-center gap-2 mb-4">
              <span class="font-sans text-brand-gold text-xs font-semibold px-2 py-1 border border-brand-gold">{post.data.tag}</span>
              <span class="text-brand-ink-3 text-xs">{new Date(post.data.date).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </div>
            <h3 class="font-serif text-brand-ink mb-3 group-hover:text-brand-gold transition-colors" style="font-size:16px;font-weight:400;line-height:1.5">{post.data.title}</h3>
            <p class="text-brand-ink-3 text-sm leading-relaxed line-clamp-3">{post.data.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 分類選單 + 文章列表 -->
  <section class="px-6 md:px-16 py-16" style="background:#f7f3ec">
    <div class="max-w-6xl mx-auto">

      <!-- 搜尋框 -->
      <div class="relative mb-6">
        <input
          id="search-input"
          type="text"
          placeholder="搜尋文章關鍵字，例如：多焦點、蔡司、兒童近視…"
          class="w-full font-sans text-sm border border-brand-ink/20 bg-white px-5 py-3 pr-12 focus:outline-none focus:border-brand-navy transition-colors"
          style="font-size:14px"
        />
        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-brand-ink-3" style="font-size:18px">🔍</span>
      </div>

      <!-- 分類 tabs -->
      <div class="flex flex-wrap gap-2 mb-10" id="tag-filters">
        <button
          data-tag="all"
          class="tag-btn font-sans text-sm px-5 py-2 border transition-colors active"
          style="border-color:var(--brand-navy);background:var(--brand-navy);color:white"
        >全部</button>
        {allTags.map(tag => (
          <button
            data-tag={tag}
            class="tag-btn font-sans text-sm px-5 py-2 border border-brand-ink/30 text-brand-ink-3 hover:border-brand-navy hover:text-brand-navy transition-colors"
          >{tag}</button>
        ))}
      </div>

      <!-- 文章列表 -->
      <div class="space-y-5" id="post-list">
        {posts.map(post => (
          <a
            href={`/blog/${post.slug}`}
            data-tag={post.data.tag}
            data-title={post.data.title}
            data-excerpt={post.data.excerpt}
            class="post-item flex flex-col sm:flex-row gap-5 border border-brand-ink/10 bg-white p-6 hover:shadow-md transition-shadow group"
          >
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="font-sans text-brand-gold text-xs font-semibold px-2 py-1 border border-brand-gold">{post.data.tag}</span>
                <span class="text-brand-ink-3 text-xs">{new Date(post.data.date).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              </div>
              <h2 class="font-serif text-brand-ink mb-2 group-hover:text-brand-gold transition-colors" style="font-size:18px;font-weight:400;line-height:1.5">{post.data.title}</h2>
              <p class="text-brand-ink-3 text-sm leading-relaxed">{post.data.excerpt}</p>
            </div>
            <div class="flex-shrink-0 self-center">
              <span class="font-sans text-brand-navy text-sm">閱讀 →</span>
            </div>
          </a>
        ))}
      </div>

      <!-- 沒有結果提示 -->
      <p id="no-results" class="text-center text-brand-ink-3 py-12 hidden" style="font-size:15px">此分類目前沒有文章</p>

    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll('.tag-btn');
    const items = document.querySelectorAll('.post-item');
    const noResults = document.getElementById('no-results');
    const searchInput = document.getElementById('search-input');

    let activeTag = 'all';

    function filterPosts() {
      const query = searchInput.value.trim().toLowerCase();
      let visible = 0;
      items.forEach(item => {
        const tagMatch = activeTag === 'all' || item.getAttribute('data-tag') === activeTag;
        const title = (item.getAttribute('data-title') || '').toLowerCase();
        const excerpt = (item.getAttribute('data-excerpt') || '').toLowerCase();
        const searchMatch = !query || title.includes(query) || excerpt.includes(query);
        const show = tagMatch && searchMatch;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      noResults.classList.toggle('hidden', visible > 0);
    }

    searchInput.addEventListener('input', filterPosts);

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        activeTag = btn.getAttribute('data-tag');

        buttons.forEach(b => {
          b.classList.remove('active');
          b.style.background = '';
          b.style.color = '';
          b.style.borderColor = '';
          b.classList.add('border-brand-ink/30', 'text-brand-ink-3');
        });
        btn.classList.add('active');
        btn.style.background = 'var(--brand-navy, #1a2e4a)';
        btn.style.color = 'white';
        btn.style.borderColor = 'var(--brand-navy, #1a2e4a)';
        btn.classList.remove('border-brand-ink/30', 'text-brand-ink-3');

        filterPosts();
      });
    });
  </script>
</Layout>
