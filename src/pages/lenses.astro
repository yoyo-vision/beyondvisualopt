---
import Layout from '../layouts/Layout.astro';

// ── 純客觀陳述：品名／系列英文名／折射率（規格）。不含任何用途、情境、功效描述 ──

// 蔡司 ZEISS 鏡片系列（品名 + 英文系列 + 折射率）
const zeiss = [
  {
    group: '單光鏡片',
    items: [
      { name: '清銳', en: 'FSV / SV ClearView', ri: '1.56 / 1.60 / 1.67 / 1.74' },
      { name: '超越型個人化', en: 'SV Superb Asiana', ri: '1.50 / 1.60 / 1.67 / 1.74' },
      { name: '頂級型個人化', en: 'SV Individual', ri: '1.50 / 1.60 / 1.67 / 1.74' },
      { name: '樹脂球面單光', en: 'SV SPH', ri: '1.50 / 1.60' },
    ],
  },
  {
    group: '智銳 SmartLife 系列',
    items: [
      { name: '智銳單光', en: 'SmartLife Young / Asiana / Individual³', ri: '1.50 / 1.60 / 1.67 / 1.74' },
      { name: '智銳 3C 數位', en: 'Digital SmartLife', ri: '1.50 / 1.60 / 1.67 / 1.74' },
      { name: '智銳多焦點', en: 'Progressive SmartLife Pure / Plus / Superb / Individual³', ri: '1.50 / 1.60 / 1.67 / 1.74' },
    ],
  },
  {
    group: '舒適多焦點',
    items: [
      { name: '舒適多焦點', en: 'Progressive Light 2（輕亮／經典／超越／個人化）', ri: '1.50 / 1.60 / 1.67 / 1.74' },
      { name: '舒適 3C 數位多焦', en: 'Digital Light 2', ri: '1.50 / 1.60 / 1.67 / 1.74' },
    ],
  },
  {
    group: '功能型系列',
    items: [
      { name: '菁悅 EnergizeMe', en: 'SV / Digital EnergizeMe', ri: '1.50 / 1.60 / 1.67 / 1.74' },
      { name: '駕車 DriveSafe', en: 'SV / Progressive DriveSafe', ri: '1.50 / 1.60 / 1.67 / 1.74' },
      { name: '新世代辦公型', en: 'Officelens Plus / Superb / Individual', ri: '1.50 / 1.60 / 1.67 / 1.74' },
    ],
  },
  {
    group: '太陽・偏光・變色',
    items: [
      { name: '個人化偏光', en: 'Superb / SmartLife Asiana Polarized', ri: '1.50 / 1.60 / 1.67' },
      { name: '運動型', en: 'SV Superb Sport（含偏光）', ri: '1.50 / 1.60 / 1.67' },
      { name: '煥視 X 變色', en: 'PhotoFusion X', ri: '依系列' },
    ],
  },
  {
    group: '成長系列',
    items: [
      { name: '成長悅', en: 'MyoKids Pro Asiana', ri: '1.50 / 1.60 / 1.67' },
      { name: '成長樂', en: 'MyoVision Pro / Ace Asiana', ri: '1.50 / 1.60 / 1.67 / 1.74' },
    ],
  },
  {
    group: '玻璃鏡片',
    items: [
      { name: '單光玻璃', en: 'SV SPH Min', ri: '1.50 / 1.60 / 1.70 / 1.80 / 1.90' },
    ],
  },
];

// HOYA 鏡片系列
const hoya = [
  {
    group: '漸進多焦點',
    items: [
      { name: '金鑽頂級個人化', en: 'MyStyle V+', ri: '1.50 / 1.60 / 1.67 / 1.74' },
      { name: '銀鑽個人化 4X', en: 'Lifestyle 4X', ri: '1.50 / 1.55 / 1.60 / 1.67 / 1.74' },
      { name: '博銳視 / 菁英 / 活力', en: 'Balansis / Dynamic Premium / Dynamic Summit', ri: '1.50 / 1.55 / 1.60 / 1.67 / 1.74' },
      { name: '飛視 PRO / 新經典', en: 'VisuPro / AMP+', ri: '1.50 / 1.55 / 1.60 / 1.67 / 1.74' },
    ],
  },
  {
    group: '室內・閱讀多焦',
    items: [
      { name: '室內頂級 / 卓越 / 智學', en: 'WorkStyle 3 / Business / WorkSmart', ri: '1.50 / 1.55 / 1.60 / 1.67 / 1.74' },
      { name: '極致閱讀', en: 'SupeReader', ri: '1.50 / 1.55 / 1.60 / 1.67' },
    ],
  },
  {
    group: '駕車鏡片',
    items: [
      { name: '駕車多焦 / 單焦', en: 'EnRoute PAL / SV（標準・專業版）', ri: '1.60 / 1.67' },
    ],
  },
  {
    group: '單焦鏡片',
    items: [
      { name: '個人化 / 雙面非球面', en: 'Nulux V+ / EP', ri: '1.60 / 1.67 / 1.74' },
      { name: '非球面 / 球面', en: 'Nulux Classic / Hilux', ri: '1.50 / 1.55 / 1.60 / 1.67 / 1.74' },
    ],
  },
];

const canonicalUrl = 'https://beyondvisualopt.com/lenses/';
const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonicalUrl,
  "url": canonicalUrl,
  "name": "鏡片種類｜蔡司 ZEISS × HOYA 鏡片系列品名一覽",
  "description": "能見度視覺中心提供的蔡司 ZEISS 與 HOYA 鏡片系列品名與折射率一覽。新莊、板橋門市。",
  "inLanguage": "zh-TW",
  "isPartOf": { "@id": "https://beyondvisualopt.com/#website" },
  "about": { "@id": "https://beyondvisualopt.com/#organization" },
};
---
<Layout
  title="鏡片種類｜蔡司 ZEISS × HOYA 鏡片系列品名一覽｜新莊板橋"
  description="能見度視覺中心提供的蔡司 ZEISS 與 HOYA 鏡片系列品名與折射率規格一覽。新莊、板橋門市，歡迎洽詢。"
  enPath="/en/lenses"
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-navy to-[#0f1e33] text-white py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-gold font-sans font-semibold tracking-widest uppercase mb-5" style="font-size:13px;letter-spacing:0.2em">鏡片種類</p>
      <h1 class="font-serif text-white leading-tight mb-6" style="font-size:clamp(30px,4.5vw,50px);font-weight:300">
        鏡片系列<span class="text-brand-gold">品名一覽</span>
      </h1>
      <p class="text-white/70 max-w-2xl mx-auto" style="font-size:17px;line-height:1.8">
        以下為門市提供的鏡片系列品名與折射率規格。實際選配與報價，歡迎洽詢門市。
      </p>
    </div>
  </section>

  <!-- 品牌供應（廠商資訊） -->
  <section class="px-6 md:px-16 py-12 border-b border-brand-ink/8" style="background:#f7f3ec">
    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-4 text-center">
      <div class="bg-white rounded-2xl p-6 border border-brand-ink/5">
        <p class="font-serif text-brand-navy mb-1" style="font-size:17px;font-weight:600">蔡司 ZEISS</p>
        <p class="text-brand-ink-3" style="font-size:13px">簽約認證經銷</p>
      </div>
      <div class="bg-white rounded-2xl p-6 border border-brand-ink/5">
        <p class="font-serif text-brand-navy mb-1" style="font-size:17px;font-weight:600">HOYA</p>
        <p class="text-brand-ink-3" style="font-size:13px">經銷</p>
      </div>
      <div class="bg-white rounded-2xl p-6 border border-brand-ink/5">
        <p class="font-serif text-brand-navy mb-1" style="font-size:17px;font-weight:600">NIKON・依視路 Essilor</p>
        <p class="text-brand-ink-3" style="font-size:13px">可代客訂購</p>
      </div>
    </div>
  </section>

  <!-- 蔡司系列品名 -->
  <section class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-8" style="font-size:clamp(24px,3.5vw,34px);font-weight:400">蔡司 ZEISS 鏡片系列</h2>
      <div class="space-y-6">
        {zeiss.map(g => (
          <div class="bg-white rounded-2xl p-6 border border-brand-ink/5">
            <h3 class="font-serif text-brand-navy mb-4 pb-2 border-b border-brand-ink/8" style="font-size:18px;font-weight:600">{g.group}</h3>
            <div class="divide-y divide-brand-ink/8">
              {g.items.map(it => (
                <div class="py-3 flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
                  <div class="sm:w-64 shrink-0">
                    <span class="font-sans text-brand-navy font-semibold" style="font-size:15px">{it.name}</span>
                    <span class="text-brand-ink-3 block" style="font-size:12px">{it.en}</span>
                  </div>
                  <span class="text-brand-gold font-sans" style="font-size:13px;letter-spacing:0.02em">折射率 {it.ri}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOYA 系列品名 -->
  <section class="px-6 md:px-16 py-20 bg-white">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-8" style="font-size:clamp(24px,3.5vw,34px);font-weight:400">HOYA 鏡片系列</h2>
      <div class="space-y-6">
        {hoya.map(g => (
          <div class="bg-brand-paper rounded-2xl p-6 border border-brand-ink/5">
            <h3 class="font-serif text-brand-navy mb-4 pb-2 border-b border-brand-ink/8" style="font-size:18px;font-weight:600">{g.group}</h3>
            <div class="divide-y divide-brand-ink/8">
              {g.items.map(it => (
                <div class="py-3 flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
                  <div class="sm:w-64 shrink-0">
                    <span class="font-sans text-brand-navy font-semibold" style="font-size:15px">{it.name}</span>
                    <span class="text-brand-ink-3 block" style="font-size:12px">{it.en}</span>
                  </div>
                  <span class="text-brand-gold font-sans" style="font-size:13px;letter-spacing:0.02em">折射率 {it.ri}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 規格選項（材質／鍍膜名稱，客觀陳述） -->
  <section class="px-6 md:px-16 py-16" style="background:#f7f3ec">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-8" style="font-size:clamp(22px,3vw,30px);font-weight:400">規格選項</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="bg-white rounded-2xl p-6 border border-brand-ink/5">
          <p class="font-sans text-brand-gold font-semibold mb-2" style="font-size:12px;letter-spacing:0.1em">折射率</p>
          <p class="text-brand-ink-2" style="font-size:14px;line-height:1.9">1.50 / 1.56 / 1.60 /<br />1.67 / 1.74（樹脂）<br />1.50–1.90（玻璃）</p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-brand-ink/5">
          <p class="font-sans text-brand-gold font-semibold mb-2" style="font-size:12px;letter-spacing:0.1em">鍍膜選項</p>
          <p class="text-brand-ink-2" style="font-size:14px;line-height:1.9">抗反射鍍膜<br />藍光過濾<br />防污防水層</p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-brand-ink/5">
          <p class="font-sans text-brand-gold font-semibold mb-2" style="font-size:12px;letter-spacing:0.1em">片種</p>
          <p class="text-brand-ink-2" style="font-size:14px;line-height:1.9">透明片<br />變色片<br />偏光片</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 免責聲明 -->
  <section class="px-6 md:px-16 py-10 bg-white">
    <div class="max-w-4xl mx-auto border border-brand-ink/10 p-5" style="background:rgba(26,47,78,0.03);font-size:13px">
      <p class="text-brand-ink-3 leading-relaxed">
        <strong class="text-brand-ink-2">說明：</strong>本頁僅列示鏡片系列品名與折射率規格，屬產品資訊陳述。實際鏡片選擇需依個人度數、散光與鏡框由驗光人員評估；鏡片報價因折射率、鍍膜與功能選項而異，請洽門市。如有視力健康疑慮，建議洽眼科醫師進行專業診斷。
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 py-20" style="background:#1a2f4e">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-white mb-4" style="font-size:clamp(24px,3.5vw,34px);font-weight:300">想了解鏡片系列與選配？</h2>
      <p class="text-white/60 mb-8" style="font-size:16px;line-height:1.8">歡迎預約視覺諮詢，由 YoYo 驗光師依你的度數與需求協助評估。新莊、板橋門市皆可預約。</p>
      <a href="/booking" class="inline-block bg-brand-gold text-brand-navy font-bold px-8 py-3.5 rounded-full hover:bg-brand-gold/90 transition-colors font-sans" style="font-size:15px">預約視覺諮詢 →</a>
    </div>
  </section>
</Layout>
