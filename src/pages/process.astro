---
import Layout from '../layouts/Layout.astro';

const steps = [
  { num: '01', title: '線上預約', desc: '透過官網、LINE OA 或 Google 行事曆選擇門市與時段，無需等候。' },
  { num: '02', title: '到店問診', desc: 'YoYo 驗光師詳細了解你的視覺困擾、日常使用習慣、工作環境與舊鏡處方。' },
  { num: '03', title: '全套儀器檢測', desc: '角膜地圖、調節力測量，搭配主客觀驗光，確立精準基準數據。' },
  { num: '04', title: '雙眼視覺評估', desc: '評估兩眼協調能力、立體視、聚散力，找出傳統驗光容易忽略的視覺問題根源。' },
  { num: '05', title: '生活視覺分析', desc: '根據你的工作距離、螢幕使用時間、戶外活動習慣，設計最適合的配鏡參數。' },
  { num: '06', title: '鏡片選配說明', desc: '不推銷，而是說明每種鏡片的光學特性與生活適配度，由你做有知識的選擇。' },
  { num: '07', title: '鏡架調整 & 訂製', desc: '頂點距離、鏡架傾斜角、鼻托高度逐一調整，確保鏡片光學中心對準你的瞳距。' },
  { num: '08', title: '取鏡 & 適應追蹤', desc: '取鏡時再次確認配戴感，提供適應期指引。有任何不適，免費回診調整。' },
];
---
<Layout
  title="服務流程｜YoYo 驗光師 8 步驟配鏡流程｜多焦點鏡片 蔡司鏡片 兒童近視追蹤｜能見度視覺中心 × 比泱驗光所"
  description="能見度視覺中心 YoYo 驗光師 8 步驟配鏡 SOP：問診 → 儀器檢測 → 雙眼視覺評估 → 生活分析 → 多焦點鏡片/蔡司鏡片/離焦鏡片選配 → 精密調整 → 取鏡追蹤。"
>
  <section class="bg-brand-navy text-white py-20 px-4 text-center">
    <h1 class="text-4xl font-bold mb-4">服務流程</h1>
    <p class="text-gray-300 text-lg max-w-2xl mx-auto">從預約到取鏡，每個步驟都有存在的理由。</p>
  </section>

  <section class="max-w-3xl mx-auto px-4 py-20">
    <div class="space-y-8">
      {steps.map((step, i) => (
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-14 h-14 bg-brand-navy text-white rounded-2xl flex items-center justify-center font-bold text-lg">
            {step.num}
          </div>
          <div class="border-l-2 border-brand-gold pl-6 pb-8 flex-1" style={i === steps.length - 1 ? 'border-left-color: transparent' : ''}>
            <h2 class="text-xl font-bold text-brand-navy mb-2">{step.title}</h2>
            <p class="text-gray-600 leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 儀器設備展示 -->
  <section class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.22em">儀器設備</span>
        <h2 class="font-serif text-brand-ink" style="font-size:clamp(24px,3.5vw,40px);font-weight:300">臨床等級的量測工具</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="overflow-hidden">
          <picture>
            <source srcset="/images/instrument-corneal-map.webp" type="image/webp" />
            <img src="/images/instrument-corneal-map.webp" alt="CA-800 角膜地形圖儀 新莊比泱驗光所 能見度視覺中心" width="600" height="400" class="w-full h-64 object-cover" loading="lazy" />
          </picture>
          <div class="pt-5">
            <h3 class="font-serif text-brand-ink mb-2" style="font-size:18px;font-weight:400">NIDEK CA-800 角膜地形圖儀</h3>
            <p class="text-brand-ink-3" style="font-size:15px;line-height:1.7">精確量測角膜弧度分布，用於 RGP 鏡片驗配評估及角膜健康狀態分析。</p>
          </div>
        </div>
        <div class="overflow-hidden">
          <picture>
            <source srcset="/images/instrument-phoropter.webp" type="image/webp" />
            <img src="/images/instrument-phoropter.webp" alt="TOPCON 綜合驗光儀 新莊比泱驗光所 主客觀驗光" width="600" height="400" class="w-full h-64 object-cover" loading="lazy" />
          </picture>
          <div class="pt-5">
            <h3 class="font-serif text-brand-ink mb-2" style="font-size:18px;font-weight:400">TOPCON 綜合驗光儀</h3>
            <p class="text-brand-ink-3" style="font-size:15px;line-height:1.7">主客觀驗光雙重確認，精準測量球面度數、散光度數與軸向，確立每位顧客的精準處方。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-light py-16 px-4 text-center">
    <h2 class="text-2xl font-bold text-brand-navy mb-4">準備好開始了嗎？</h2>
    <a href="/booking" class="bg-brand-navy text-white font-bold px-8 py-4 rounded-full hover:bg-brand-navy/90 transition-colors inline-block">
      預約視覺分析 →
    </a>
  </section>
</Layout>
