---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "新莊哪裡有專業驗光？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "能見度視覺中心（比泱驗光所）位於新北市新莊區中正路，由 YoYo 驗光師主理，提供完整臨床驗光、雙眼視覺評估、兒童近視追蹤與多焦點鏡片配製服務。"
      }
    },
    {
      "@type": "Question",
      "name": "老花一定要配多焦點嗎？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "不一定。老花的解決方案包含單焦老花鏡、漸進多焦點鏡片、甚至接觸鏡選項。多焦點鏡片適合需要頻繁切換遠中近距離的生活型態，但工作以近距離為主者不一定適合。YoYo 驗光師會根據你的生活習慣給出最適合的建議，而非一律推薦最貴的方案。"
      }
    },
    {
      "@type": "Question",
      "name": "為什麼戴眼鏡會頭暈？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "戴眼鏡頭暈的原因包括：度數配錯、散光軸向偏差、鏡片光學中心偏移、鏡架調整不當導致傾斜角問題，或高度近視眼鏡的棱鏡效應。能見度視覺中心提供免費回診評估，YoYo 驗光師可協助找出確切原因。"
      }
    },
    {
      "@type": "Question",
      "name": "兒童近視應該多久追蹤一次？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "建議每 3–6 個月回診追蹤一次。能見度視覺中心新莊店（比泱驗光所）提供兒童近視定期追蹤服務，由 YoYo 驗光師進行完整視力評估、度數變化紀錄與離焦鏡片配適建議，協助家長掌握孩子視力發展趨勢。藥物相關治療（如低濃度阿托品）請諮詢眼科醫師。"
      }
    },
    {
      "@type": "Question",
      "name": "板橋哪裡可以配蔡司鏡片？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "能見度眼鏡 × 能見度驗光所位於新北市板橋區，為蔡司 Zeiss 簽約經銷商，提供 Individual² 個人化訂製蔡司鏡片、多焦點鏡片與高度近視眼鏡解決方案。"
      }
    }
  ]
};
---
<Layout
  title="能見度眼鏡｜新莊板橋驗光所 蔡司鏡片 多焦點鏡片 高度近視 數位疲勞｜YoYo 驗光師"
  description="新莊・板橋專業驗光｜能見度眼鏡。蔡司 Zeiss 鏡片、多焦點鏡片、兒童近視追蹤、高度近視配鏡。YoYo 驗光師主理，預約免費視覺分析。"
  keywords="新莊驗光,新莊眼鏡行推薦,新莊驗光所,新莊配眼鏡,板橋驗光,板橋眼鏡行推薦,板橋配眼鏡,板橋驗光所,新北驗光推薦,新莊多焦點鏡片,新莊漸進鏡片,新莊蔡司鏡片,板橋多焦點鏡片,板橋蔡司鏡片,新莊老花眼鏡,板橋老花眼鏡,新莊高度近視眼鏡,新莊兒童近視追蹤,戴眼鏡為什麼頭暈,老花一定要配多焦點嗎,漸進鏡片為什麼會暈,高度近視要怎麼配眼鏡,數位疲勞眼鏡,RGP硬式隱形眼鏡,蔡司Zeiss,HOYA鏡片,NIKON鏡片,ESSILOR鏡片,能見度眼鏡,能見度視覺中心,比泱驗光所,能見度驗光所,YoYo驗光師,鄭家侑驗光師"
  schema={faqSchema}
>
  <!-- Hero -->
  <section class="relative text-white py-28 px-6 overflow-hidden">
    <picture>
      <source srcset="/images/store-interior-hero.webp" type="image/webp" />
      <img src="/images/store-interior-hero.webp" alt="能見度眼鏡新莊門市內部" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" width="1920" height="1080" />
    </picture>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy/90 to-[#0f1e33]/85"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <p class="text-brand-gold font-sans font-semibold tracking-widest uppercase mb-5" style="font-size:13px;letter-spacing:0.2em">新北市新莊 × 板橋｜深耕在地 30 年專業驗光</p>
      <h1 class="font-serif text-white leading-tight mb-7" style="font-size:clamp(32px,5.5vw,62px);font-weight:300">
        能見度眼鏡｜新莊驗光所 × 板橋眼鏡行<br /><span class="text-brand-gold">蔡司鏡片</span>｜多焦點鏡片｜兒童近視追蹤
      </h1>
      <p class="text-white/75 max-w-2xl mx-auto mb-10" style="font-size:18px;line-height:1.85">
        新莊與板橋在地深耕超過 30 年的專業眼鏡行。從兒童近視追蹤到熟齡族老花配鏡，提供醫療級驗光流程與國際鏡片品牌，為你打造真正適合的清晰視界。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/booking"
          class="font-sans bg-brand-gold text-brand-navy font-bold px-8 py-4 hover:bg-brand-gold/90 transition-colors"
          style="font-size:16px">
          立即預約視覺分析
        </a>
        <a href="/services"
          class="font-sans border border-white/40 text-white font-semibold px-8 py-4 hover:bg-white/10 transition-colors"
          style="font-size:16px">
          了解服務內容
        </a>
      </div>
    </div>
  </section>

  <!-- 核心優勢 -->
  <section class="px-6 md:px-16 py-24" style="background:#eee8da">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-16 mb-16 items-end">
        <h2 class="font-serif text-brand-ink" style="font-size:clamp(32px,4.5vw,56px);font-weight:300;line-height:1.15">
          新莊、板橋配眼鏡<br />不只是選個框架那麼簡單
        </h2>
        <p class="text-brand-ink-2" style="font-size:18px;line-height:1.8">
          每一次進門，我們做的不是快速出貨，而是完整了解你的視覺狀態、生活習慣與真正的需求，才給出建議。
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { num: '01', title: '新莊驗光所｜臨床等級驗光', desc: '完整雙眼視覺評估、頂點距離量測、鏡片傾斜角調整，每個參數精準到位，而不是十分鐘驗完出貨。' },
          { num: '02', title: '蔡司 Zeiss 簽約經銷商', desc: '新莊、板橋蔡司鏡片正式簽約經銷商。Individual² 個人化訂製、多焦點漸進鏡片、數位防護系列，原廠品質有憑有據。' },
          { num: '03', title: '新莊兒童近視追蹤', desc: '針對 6–14 歲兒童提供定期視力評估與度數變化追蹤，搭配離焦設計鏡片，協助家長掌握孩子視力發展趨勢。' },
        ].map(item => (
          <div class="border-t border-brand-ink/20 pt-8">
            <div class="font-sans text-brand-ink-3 mb-4" style="font-size:12px;letter-spacing:0.2em">{item.num}</div>
            <h3 class="font-serif text-brand-ink mb-4" style="font-size:22px;font-weight:400">{item.title}</h3>
            <p class="text-brand-ink-2" style="font-size:16px;line-height:1.8">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- YoYo 驗光師 -->
  <section style="background:#f7f3ec">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row">
        <!-- 左：大圖，無 padding，滿版 -->
        <div class="w-full md:w-1/2 shrink-0">
          <picture>
            <source srcset="/images/yoyo-optometrist.webp" type="image/webp" />
            <img src="/images/yoyo-optometrist.jpg"
              alt="YoYo 驗光師 鄭家侑 能見度視覺中心 比泱驗光所"
              width="720" height="860"
              class="w-full object-cover object-top"
              style="filter:sepia(8%);min-height:480px;max-height:640px" />
          </picture>
        </div>
        <!-- 右：文字區 -->
        <div class="w-full md:w-1/2 flex items-center px-10 md:px-16 py-20">
          <div>
            <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-5" style="font-size:12px;letter-spacing:0.22em">主理驗光師</span>
            <h2 class="font-serif text-brand-ink mb-3" style="font-size:clamp(28px,3.5vw,46px);font-weight:300;line-height:1.2">
              鄭家侑 驗光師<br /><span style="font-size:0.65em;color:#8a7f72">YoYo・驗師字第 003309 號</span>
            </h2>
            <div class="w-12 border-t border-brand-gold mt-5 mb-7"></div>
            <p class="text-brand-ink-2 mb-5" style="font-size:17px;line-height:1.9">
              能見度視覺中心 × 比泱驗光所主理驗光師。專精臨床驗光、雙眼視覺評估、多焦點鏡片配製與兒童近視追蹤。
            </p>
            <p class="text-brand-ink-2 mb-8" style="font-size:17px;line-height:1.9">
              每一位顧客都有完整的時間說清楚視覺困擾——不趕人、不話術、真的聽你說。
            </p>
            <p class="text-brand-ink-3 italic mb-10" style="font-size:17px;line-height:1.85;border-left:3px solid #c9a84c;padding-left:1.2rem">
              「不追求最貴，只追求最適合你的視覺解決方案。」
            </p>
            <a href="/booking"
              class="font-sans inline-flex items-center gap-3 bg-brand-ink text-brand-paper px-8 py-4 hover:bg-brand-navy transition-colors duration-300"
              style="font-size:14px;letter-spacing:0.12em">
              預約 YoYo 驗光師
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 兩大門市介紹 -->
  <section class="px-6 md:px-16 py-24 border-t border-brand-ink/10" style="background:#eee8da">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.22em">Two Locations</span>
        <h2 class="font-serif text-brand-ink" style="font-size:clamp(28px,4vw,48px);font-weight:300">新莊 × 板橋｜兩大門市</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- 新莊 -->
        <div class="bg-brand-paper border border-brand-ink/10 overflow-hidden">
          <picture>
            <source srcset="/images/store-xinzhuang.webp" type="image/webp" />
            <img src="/images/store-xinzhuang.jpg" alt="能見度視覺中心 比泱驗光所 新莊門市" width="600" height="240" class="w-full h-60 object-cover" style="filter:sepia(6%)" />
          </picture>
          <div class="p-8">
            <span class="font-sans text-brand-ink-3 text-xs tracking-widest uppercase block mb-3" style="letter-spacing:0.18em">新莊店・2023年成立</span>
            <h3 class="font-serif text-brand-ink mb-1" style="font-size:22px;font-weight:400">能見度視覺中心 × 比泱驗光所</h3>
            <p class="text-brand-ink-3 mb-5" style="font-size:14px">臨床驗光・雙眼視覺・兒童近視追蹤</p>
            <div class="space-y-1 mb-6 text-brand-ink-2" style="font-size:15px">
              <p>📍 新北市新莊區中正路 419-1 號</p>
              <p>📞 <a href="tel:0222066700" class="hover:text-brand-ink transition-colors">02-2206-6700</a></p>
              <p class="text-brand-ink-3" style="font-size:13px">週一～六 11:00–21:00・週日 12:00–21:00・週四公休</p>
            </div>
            <a href="/xinzhuang/"
              class="font-sans inline-flex items-center gap-2 border border-brand-ink text-brand-ink px-5 py-2.5 hover:bg-brand-ink hover:text-brand-paper transition-colors duration-300"
              style="font-size:13px;letter-spacing:0.08em">
              門市詳情 →
            </a>
          </div>
        </div>

        <!-- 板橋 -->
        <div class="bg-brand-paper border border-brand-ink/10 overflow-hidden">
          <picture>
            <source srcset="/images/store-banqiao.webp" type="image/webp" />
            <img src="/images/store-banqiao.jpg" alt="能見度眼鏡 能見度驗光所 板橋門市" width="600" height="240" class="w-full h-60 object-cover" style="filter:sepia(6%)" />
          </picture>
          <div class="p-8">
            <span class="font-sans text-brand-ink-3 text-xs tracking-widest uppercase block mb-3" style="letter-spacing:0.18em">板橋總店・1992年創立</span>
            <h3 class="font-serif text-brand-ink mb-1" style="font-size:22px;font-weight:400">能見度眼鏡 × 能見度驗光所</h3>
            <p class="text-brand-ink-3 mb-5" style="font-size:14px">蔡司 Zeiss・多焦點鏡片・熟齡老花配鏡</p>
            <div class="space-y-1 mb-6 text-brand-ink-2" style="font-size:15px">
              <p>📍 新北市板橋區雙十路二段 47 巷 28 號</p>
              <p>📞 <a href="tel:0222531246" class="hover:text-brand-ink transition-colors">02-2253-1246</a></p>
              <p class="text-brand-ink-3" style="font-size:13px">每日 10:00–22:00・每月第二、四週日公休</p>
            </div>
            <a href="/banqiao/"
              class="font-sans inline-flex items-center gap-2 border border-brand-ink text-brand-ink px-5 py-2.5 hover:bg-brand-ink hover:text-brand-paper transition-colors duration-300"
              style="font-size:13px;letter-spacing:0.08em">
              門市詳情 →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 客戶評價 -->
  <section class="px-6 md:px-16 py-24" style="background:#f7f3ec">
    <div class="max-w-6xl mx-auto">

      <!-- 標題 + 評分總覽 -->
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div>
          <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.22em">Google 真實評價</span>
          <h2 class="font-serif text-brand-ink" style="font-size:clamp(28px,4vw,48px);font-weight:300">新莊與板橋地區<br />的信賴選擇</h2>
        </div>
        <div class="flex gap-8">
          <div id="rating-xinzhuang" class="text-center">
            <div class="font-serif text-brand-ink" style="font-size:36px;font-weight:300;line-height:1">—</div>
            <div class="flex justify-center gap-0.5 my-1" id="stars-xinzhuang"></div>
            <div class="font-sans text-brand-ink-3" style="font-size:12px">新莊店</div>
          </div>
          <div id="rating-banqiao" class="text-center">
            <div class="font-serif text-brand-ink" style="font-size:36px;font-weight:300;line-height:1">—</div>
            <div class="flex justify-center gap-0.5 my-1" id="stars-banqiao"></div>
            <div class="font-sans text-brand-ink-3" style="font-size:12px">板橋店</div>
          </div>
        </div>
      </div>

      <!-- 評論卡片 -->
      <div id="reviews-grid" class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- 載入中佔位 -->
        {[1,2,3].map(() => (
          <div class="border-t border-brand-ink/15 pt-7 animate-pulse">
            <div class="h-3 bg-brand-ink/8 rounded mb-4 w-24"></div>
            <div class="space-y-2 mb-5">
              <div class="h-3 bg-brand-ink/8 rounded w-full"></div>
              <div class="h-3 bg-brand-ink/8 rounded w-4/5"></div>
              <div class="h-3 bg-brand-ink/8 rounded w-3/5"></div>
            </div>
            <div class="h-3 bg-brand-ink/8 rounded w-20"></div>
          </div>
        ))}
      </div>

      <!-- 顧客實拍照牆 -->
      <div id="photo-wall" class="mt-14 hidden">
        <div class="flex items-center justify-between mb-4">
          <span class="font-sans text-brand-ink-3" style="font-size:12px;letter-spacing:0.18em">顧客實拍・來自 Google Maps</span>
        </div>
        <div id="photo-grid" class="grid grid-cols-3 md:grid-cols-6 gap-2"></div>
      </div>

      <!-- Lightbox -->
      <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center" style="background:rgba(0,0,0,0.85)" onclick="this.classList.add('hidden');this.classList.remove('flex')">
        <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain" style="max-height:90vh;max-width:90vw">
      </div>

      <!-- 按鈕 -->
      <div class="flex flex-col sm:flex-row justify-center gap-4 mt-12">
        <a href="https://share.google/rMxJYqYZH6fR4QwrS" target="_blank" rel="noopener noreferrer"
          class="font-sans flex items-center justify-center gap-2 border border-brand-ink/25 text-brand-ink-2 px-6 py-3 hover:border-brand-ink transition-colors" style="font-size:14px">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          新莊店 Google 評論
        </a>
        <a href="https://share.google/lReL1vW8OEUXZBeVy" target="_blank" rel="noopener noreferrer"
          class="font-sans flex items-center justify-center gap-2 border border-brand-ink/25 text-brand-ink-2 px-6 py-3 hover:border-brand-ink transition-colors" style="font-size:14px">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          板橋店 Google 評論
        </a>
      </div>

    </div>
  </section>

  <script>
    const GOOGLE_G = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>';

    function stars(n) {
      return Array(5).fill(0).map((_, i) =>
        '<span style="color:' + (i < n ? '#c9a84c' : '#d1c9bc') + ';font-size:14px">★</span>'
      ).join('');
    }

    async function loadReviews() {
      try {
        const [rxRes, rbRes] = await Promise.all([
          fetch('/api/google-reviews?store=xinzhuang'),
          fetch('/api/google-reviews?store=banqiao'),
        ]);
        const rx = await rxRes.json();
        const rb = await rbRes.json();

        // 評分總覽
        document.querySelector('#rating-xinzhuang div').textContent = rx.rating?.toFixed(1) || '—';
        document.getElementById('stars-xinzhuang').innerHTML = stars(Math.round(rx.rating || 0));
        document.querySelector('#rating-banqiao div').textContent = rb.rating?.toFixed(1) || '—';
        document.getElementById('stars-banqiao').innerHTML = stars(Math.round(rb.rating || 0));

        // 合併評論，新莊優先取 4 則，板橋取 2 則
        const combined = [
          ...(rx.reviews || []).slice(0, 4).map(r => ({ ...r, store: '新莊店' })),
          ...(rb.reviews || []).slice(0, 2).map(r => ({ ...r, store: '板橋店' })),
        ];

        if (!combined.length) return;

        document.getElementById('reviews-grid').innerHTML = combined.map(function(r) {
          var shortText = r.text.length > 120 ? r.text.slice(0, 120) + '…' : r.text;
          var initial = r.author ? r.author.charAt(0) : '?';
          var avatarHtml = '<div class="w-8 h-8 rounded-full flex-shrink-0 flex items-center justify-center font-sans text-white" style="background:#2a3f5f;font-size:14px;font-weight:500">' + initial + '</div>';
          var maskedName = r.author ? r.author.charAt(0) + (r.author.length > 1 ? '**' : '') : '匿名';
          return '<div class="border-t border-brand-ink/15 pt-7">'
            + '<div class="flex items-center gap-2 mb-3">'
            + avatarHtml
            + '<div>'
            + '<div class="font-sans text-brand-ink" style="font-size:14px;font-weight:500">' + maskedName + '</div>'
            + '<div class="font-sans text-brand-ink-3" style="font-size:11px">' + r.store + '・' + r.time + '</div>'
            + '</div>'
            + '<span class="ml-auto flex-shrink-0">' + GOOGLE_G + '</span>'
            + '</div>'
            + '<div class="flex gap-0.5 mb-3">' + stars(r.rating) + '</div>'
            + '<p class="text-brand-ink-2" style="font-size:16px;line-height:1.8">「' + shortText + '」</p>'
            + '</div>';
        }).join('');
        // 照片牆：合併兩店照片，最多 9 張
        var allPhotos = [
          ...(rx.photos || []).slice(0, 6),
          ...(rb.photos || []).slice(0, 3),
        ];

        if (allPhotos.length) {
          var grid = document.getElementById('photo-grid');
          grid.innerHTML = allPhotos.map(function(name) {
            var src = '/api/place-photo?name=' + encodeURIComponent(name);
            return '<div class="cursor-pointer overflow-hidden" style="aspect-ratio:1" onclick="var lb=document.getElementById(\'lightbox\');document.getElementById(\'lightbox-img\').src=\'' + src + '\';lb.classList.remove(\'hidden\');lb.classList.add(\'flex\')">'
              + '<img src="' + src + '" alt="能見度視覺中心顧客實拍" loading="lazy" width="300" height="300" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">'
              + '</div>';
          }).join('');
          document.getElementById('photo-wall').classList.remove('hidden');
        }
      } catch(e) {
        console.error('Google Reviews load error:', e);
      }
    }

    // Defer reviews load until the section enters viewport
    var reviewsSection = document.getElementById('reviews-grid');
    if ('IntersectionObserver' in window && reviewsSection) {
      var io = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) {
          io.disconnect();
          loadReviews();
        }
      }, { rootMargin: '200px' });
      io.observe(reviewsSection);
    } else {
      loadReviews();
    }
  </script>

  <!-- FAQ -->
  <section class="px-6 md:px-16 py-24 border-t border-brand-ink/10" style="background:#eee8da">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-14" style="font-size:clamp(28px,4vw,48px);font-weight:300">常見問題</h2>
      <div class="space-y-0">
        {[
          { q: '老花一定要配多焦點嗎？', a: '不一定。老花的解決方案包含：單焦老花鏡、漸進多焦點鏡片、甚至接觸鏡選項。多焦點鏡片適合需要頻繁切換遠中近距離者，但工作以近距離為主的人不一定適合。YoYo 驗光師會根據你的真實生活習慣給出建議，而非一律推薦多焦點。' },
          { q: '為什麼戴眼鏡會頭暈？', a: '戴眼鏡頭暈最常見的原因：度數配錯、散光軸向偏差、鏡片光學中心偏移、鏡架調整不當造成傾斜角問題。高度近視眼鏡尤其敏感，任何一個細節失準都會放大不適感。能見度視覺中心提供免費回診評估。' },
          { q: '離焦鏡片對孩子的近視追蹤有幫助嗎？', a: '有幫助，但效果因人而異，需定期追蹤評估。MiSight 離焦日拋與蔡司星趣控等離焦設計鏡片，在國際臨床研究中已顯示可協助減緩近視加深趨勢。YoYo 驗光師會透過定期視力評估，為家長提供度數變化紀錄與鏡片適配建議。藥物治療（如低濃度阿托品）屬醫療處方，請洽眼科醫師評估。' },
          { q: '蔡司鏡片和普通鏡片差在哪裡？', a: '蔡司鏡片（Zeiss）的差異在於個人化光學計算：Individual² 系列根據你的頭部轉動習慣、眼球運動模式與實際配戴姿勢客製化設計，清晰視野範圍比標準鏡片大 20% 以上。能見度視覺中心為蔡司 Zeiss 簽約經銷商。' },
        ].map(item => (
          <details class="border-t border-brand-ink/15 group">
            <summary class="flex justify-between items-center py-5 cursor-pointer text-brand-ink hover:text-brand-navy transition-colors" style="font-size:18px;font-weight:400;list-style:none">
              {item.q}
              <span class="font-sans text-brand-ink-3 text-2xl ml-4 group-open:rotate-45 transition-transform flex-shrink-0">+</span>
            </summary>
            <p class="pb-6 text-brand-ink-2" style="font-size:17px;line-height:1.85">{item.a}</p>
          </details>
        ))}
        <div class="border-t border-brand-ink/15"></div>
      </div>

      <!-- Google 地圖 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
        <div>
          <p class="font-sans text-brand-ink-3 mb-2" style="font-size:12px;letter-spacing:0.12em">新莊店｜中正路 419-1 號</p>
          <iframe
            src="https://maps.google.com/maps?q=新北市新莊區中正路419-1號&output=embed&hl=zh-TW&z=16"
            width="100%" height="220" style="border:0;display:block"
