---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "新莊哪裡有專業驗光？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "能見度視覺中心（比泱驗光所）位於新北市新莊區中正路，由 YoYo 驗光師主理，提供完整臨床驗光、雙眼視覺評估、兒童近視追蹤與多焦點鏡片配製服務。"
      }
    },
    {
      "@type": "Question",
      "name": "老花一定要配多焦點嗎？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "不一定。老花的解決方案包含單焦老花鏡、漸進多焦點鏡片、甚至接觸鏡選項。多焦點鏡片適合需要頻繁切換遠中近距離的生活型態，但工作以近距離為主者不一定適合。YoYo 驗光師會根據你的生活習慣給出最適合的建議，而非一律推薦最貴的方案。"
      }
    },
    {
      "@type": "Question",
      "name": "為什麼戴眼鏡會頭暈？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "戴眼鏡頭暈的原因包括：度數配錯、散光軸向偏差、鏡片光學中心偏移、鏡架調整不當導致傾斜角問題，或高度近視眼鏡的棱鏡效應。能見度視覺中心提供免費回診評估，YoYo 驗光師可協助找出確切原因。"
      }
    },
    {
      "@type": "Question",
      "name": "兒童近視應該多久追蹤一次？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "建議每 3–6 個月回診追蹤一次。能見度視覺中心新莊店（比泱驗光所）提供兒童近視定期追蹤服務，由 YoYo 驗光師進行完整視力評估、度數變化紀錄與離焦鏡片配適建議，協助家長掌握孩子視力發展趨勢。藥物相關治療（如低濃度阿托品）請諮詢眼科醫師。"
      }
    },
    {
      "@type": "Question",
      "name": "板橋哪裡可以配蔡司鏡片？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "能見度眼鏡 × 能見度驗光所位於新北市板橋區，為蔡司 Zeiss 簽約經銷商，提供 Individual² 個人化訂製蔡司鏡片、多焦點鏡片與高度近視眼鏡解決方案。"
      }
    }
  ]
};

// 驗配流程：以真實 8 步驟分三階段呈現，讓首頁具備 H2→H3→H4 的內容深度（GEO 友善）
const processPhases = [
  {
    stage: '第一階段',
    title: '先了解你',
    en: 'Understand',
    steps: [
      { num: '01', name: '線上預約', desc: '透過官網、LINE OA 或 Google 行事曆選擇門市與時段，到店不必久候。' },
      { num: '02', name: '到店問診', desc: 'YoYo 驗光師詳細了解你的視覺困擾、日常用眼習慣、工作環境與舊鏡處方——這比視力表更早決定一副眼鏡好不好戴。' },
    ],
  },
  {
    stage: '第二階段',
    title: '精準檢測',
    en: 'Measure',
    steps: [
      { num: '03', name: '全套儀器檢測', desc: '角膜地形圖、調節力測量搭配主客觀驗光，把度數、散光、軸度反覆比對到最清楚為止。' },
      { num: '04', name: '雙眼視覺評估', desc: '評估兩眼協調、立體視與聚散能力，找出傳統驗光容易忽略、卻是長時間閱讀會不會累的根源。' },
      { num: '05', name: '生活視覺分析', desc: '依你的工作距離、螢幕時數與戶外習慣，決定配鏡參數該落在哪裡——鏡片是為你的生活做的，不是為視力表。' },
    ],
  },
  {
    stage: '第三階段',
    title: '為你打造',
    en: 'Build',
    steps: [
      { num: '06', name: '鏡片選配說明', desc: '不推銷，而是說明每種鏡片的光學特性與生活適配度，讓你在理解之後自己選。' },
      { num: '07', name: '鏡架調整與訂製', desc: '頂點距離、傾斜角、鼻托高度逐一調整，確保鏡片光學中心對準你的瞳距。' },
      { num: '08', name: '取鏡與適應追蹤', desc: '取鏡時再次確認配戴感並提供適應期指引，有任何不適免費回診調整。' },
    ],
  },
];
---
<Layout
  title="能見度眼鏡｜能見度視覺中心・比泱驗光所｜新莊板橋蔡司多焦點"
  description="新莊・板橋專業驗光｜能見度眼鏡。蔡司 Zeiss 鏡片、多焦點鏡片、兒童近視追蹤、高度近視配鏡。YoYo 驗光師主理，預約免費視覺分析。"
  keywords="新莊驗光,新莊眼鏡行推薦,新莊驗光所,新莊配眼鏡,板橋驗光,板橋眼鏡行推薦,板橋配眼鏡,板橋驗光所,新北驗光推薦,新莊多焦點鏡片,新莊漸進鏡片,新莊蔡司鏡片,板橋多焦點鏡片,板橋蔡司鏡片,新莊老花眼鏡,板橋老花眼鏡,新莊高度近視眼鏡,新莊兒童近視追蹤,戴眼鏡為什麼頭暈,老花一定要配多焦點嗎,漸進鏡片為什麼會暈,高度近視要怎麼配眼鏡,數位疲勞眼鏡,RGP硬式隱形眼鏡,蔡司Zeiss,HOYA鏡片,NIKON鏡片,ESSILOR鏡片,能見度眼鏡,能見度視覺中心,比泱驗光所,能見度驗光所,YoYo驗光師,鄭家侑驗光師"
  schema={faqSchema}
  preloadHeroMobile="/images/store-interior-hero-mobile.webp"
  preloadHeroDesktop="/images/store-interior-hero.webp"
  enPath="/en"
>
  <!-- Hero -->
  <section class="relative text-white py-28 px-6 overflow-hidden">
    <picture>
      <source media="(max-width: 768px)" srcset="/images/store-interior-hero-mobile.webp" type="image/webp" />
      <source srcset="/images/store-interior-hero.webp" type="image/webp" />
      <img src="/images/store-interior-hero.webp" alt="能見度眼鏡新莊門市內部" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" width="1920" height="1080" />
    </picture>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy/90 to-[#0f1e33]/85"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <p class="text-brand-gold font-sans font-semibold tracking-widest uppercase mb-5" style="font-size:13px;letter-spacing:0.2em">新北市新莊 × 板橋｜深耕在地 30 年專業驗光</p>
      <h1 class="font-serif text-white leading-tight mb-7" style="font-size:clamp(32px,5.5vw,62px);font-weight:300">
        眼鏡不是越貴越好，<br />是越<span class="text-brand-gold">適合你</span>越好
      </h1>
      <p class="text-white/75 max-w-2xl mx-auto mb-10" style="font-size:18px;line-height:1.85">
        我們是在新莊、板橋深耕 30 年的眼鏡行。從孩子的近視追蹤到爸媽的老花配鏡，先花時間搞懂你怎麼用眼睛，再幫你挑真正適合的那一副——不是最貴的，是最對的。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/booking"
          class="font-sans bg-brand-gold text-brand-navy font-bold px-8 py-4 hover:bg-brand-gold/90 transition-colors"
          style="font-size:16px">
          立即預約視覺分析
        </a>
        <a href="/services"
          class="font-sans border border-white/40 text-white font-semibold px-8 py-4 hover:bg-white/10 transition-colors"
          style="font-size:16px">
          了解服務內容
        </a>
      </div>
    </div>
  </section>

  <!-- 信任狀前置帶：資格・經銷・儀器・年資・評價，正面對打競品的認證/儀器權威牌（法務 🟡 已套改寫版：臨床級→專業、刪無據「三代信賴」） -->
  <section class="px-6 md:px-16 py-10 border-b border-brand-ink/10" style="background:#f7f3ec">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-x-6 gap-y-8 md:divide-x md:divide-brand-ink/10">
        {[
          { t: '國考持證驗光師主理', s: '鄭家侑（YoYo）／驗師字第 003309 號' },
          { t: '蔡司 Zeiss 簽約經銷門市', s: '原廠簽約經銷，經銷憑證可查' },
          { t: '專業檢測儀器', s: 'NIDEK 角膜地形圖儀・TOPCON 綜合驗光儀' },
          { t: '深耕在地 30 年', s: '板橋總店 1992 年創立，在地服務逾 30 年' },
          { t: 'Google 5.0・222 則評價', s: '新莊店真實顧客評分' },
        ].map((item, i) => (
          <div class={i === 0 ? 'md:pl-0 md:px-5' : 'md:px-5'}>
            <div class="w-6 border-t-2 border-brand-gold mb-3"></div>
            <div class="font-serif text-brand-navy mb-1.5" style="font-size:16px;font-weight:600;line-height:1.4">{item.t}</div>
            <div class="font-sans text-brand-ink-3" style="font-size:12.5px;line-height:1.6">{item.s}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 核心優勢 -->
  <section class="px-6 md:px-16 py-24" style="background:#eee8da">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-16 mb-16 items-end">
        <h2 class="font-serif text-brand-ink" style="font-size:clamp(32px,4.5vw,56px);font-weight:300;line-height:1.15">
          配眼鏡，我們在意的<br />不只是你戴起來好不好看
        </h2>
        <p class="text-brand-ink-2" style="font-size:18px;line-height:1.8">
          在新莊、板橋配眼鏡，我們不急著讓你出貨。先坐下來，把你的用眼習慣、生活狀態、之前哪裡不舒服都聊清楚，再給建議。
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { num: '01', title: '驗光，不是量個度數就結束', desc: '在新莊，我們做的是完整的臨床驗光——雙眼視覺評估、頂點距離量測、鏡片傾斜角調整，每個參數都對到位，而不是十分鐘驗完就叫你等取貨。' },
          { num: '02', title: '要用好鏡片，我們有蔡司原廠', desc: '新莊、板橋蔡司 Zeiss 正式簽約經銷商。從 Individual² 個人化訂製、多焦點漸進到數位鏡片（藍光過濾設計），原廠品質，經銷憑證可查。' },
          { num: '03', title: '孩子的近視，我們幫你一起盯', desc: '6–14 歲的孩子，我們提供定期視力檢查與度數變化追蹤，搭配離焦光學設計鏡片，讓你清楚看見孩子這半年、這一年的視力走向。依驗光人員法，十五歲以下者之驗光於眼科醫師指導下進行，需要時協同眼科醫師轉診追蹤。' },
        ].map(item => (
          <div class="border-t border-brand-ink/20 pt-8">
            <div class="font-sans text-brand-ink-3 mb-4" style="font-size:12px;letter-spacing:0.2em">{item.num}</div>
            <h3 class="font-serif text-brand-ink mb-4" style="font-size:22px;font-weight:400">{item.title}</h3>
            <p class="text-brand-ink-2" style="font-size:16px;line-height:1.8">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- YoYo 驗光師 -->
  <section style="background:#f7f3ec">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row">
        <!-- 左：大圖，無 padding，滿版 -->
        <div class="w-full md:w-1/2 shrink-0">
          <picture>
            <source srcset="/images/yoyo-optometrist.webp" type="image/webp" />
            <img src="/images/yoyo-optometrist.webp"
              alt="YoYo 驗光師 鄭家侑 能見度視覺中心 比泱驗光所"
              width="720" height="860"
              class="w-full object-cover object-top"
              style="filter:sepia(8%);min-height:480px;max-height:640px" />
          </picture>
        </div>
        <!-- 右：文字區 -->
        <div class="w-full md:w-1/2 flex items-center px-10 md:px-16 py-20">
          <div>
            <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-5" style="font-size:12px;letter-spacing:0.22em">主理驗光師</span>
            <h2 class="font-serif text-brand-ink mb-3" style="font-size:clamp(28px,3.5vw,46px);font-weight:300;line-height:1.2">
              鄭家侑 驗光師<br /><span style="font-size:0.65em;color:#8a7f72">YoYo・驗師字第 003309 號</span>
            </h2>
            <div class="w-12 border-t border-brand-gold mt-5 mb-7"></div>
            <p class="text-brand-ink-2 mb-5" style="font-size:17px;line-height:1.9">
              能見度視覺中心 × 比泱驗光所主理驗光師。專精臨床驗光、雙眼視覺評估、多焦點鏡片配製與兒童近視追蹤。
            </p>
            <p class="text-brand-ink-2 mb-8" style="font-size:17px;line-height:1.9">
              每一位顧客都有完整的時間說清楚視覺困擾——不趕人、不話術、真的聽你說。
            </p>
            <p class="text-brand-ink-3 italic mb-10" style="font-size:17px;line-height:1.85;border-left:3px solid #c9a84c;padding-left:1.2rem">
              「不追求最貴，只追求最適合你的視覺解決方案。」
            </p>
            <a href="/booking"
              class="font-sans inline-flex items-center gap-3 bg-brand-ink text-brand-paper px-8 py-4 hover:bg-brand-navy transition-colors duration-300"
              style="font-size:14px;letter-spacing:0.12em">
              預約 YoYo 驗光師
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 專業驗配流程（8 步驟／三階段：提供 H2→H3→H4 內容深度） -->
  <section class="px-6 md:px-16 py-24" style="background:#1a2f4e">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-2xl mb-16">
        <span class="font-sans text-brand-gold tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.22em">The Process</span>
        <h2 class="font-serif text-brand-paper mb-6" style="font-size:clamp(28px,4vw,48px);font-weight:300;line-height:1.2">
          配一副眼鏡，<br />我們會陪你走完這 8 步
        </h2>
        <p class="text-brand-paper/65" style="font-size:18px;line-height:1.85">
          驗光不該是十分鐘的例行公事。從你坐下來的第一句話，到戴上眼鏡走出門，這八步我們一步都不跳——每一步都有它該在的理由，不是湊時間。
        </p>
      </div>

      <div class="space-y-14">
        {processPhases.map(phase => (
          <div class="grid grid-cols-1 md:grid-cols-4 gap-8 border-t border-brand-gold/25 pt-10">
            <div>
              <span class="font-sans text-brand-gold block mb-2" style="font-size:12px;letter-spacing:0.2em">{phase.en}</span>
              <h3 class="font-serif text-brand-paper" style="font-size:24px;font-weight:400">{phase.stage}<br /><span class="text-brand-paper/70" style="font-size:0.72em">{phase.title}</span></h3>
            </div>
            <div class="md:col-span-3 grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-8">
              {phase.steps.map(step => (
                <div>
                  <div class="font-sans text-brand-gold/70 mb-2" style="font-size:12px;letter-spacing:0.15em">{step.num}</div>
                  <h4 class="font-serif text-brand-paper mb-2" style="font-size:19px;font-weight:400">{step.name}</h4>
                  <p class="text-brand-paper/60" style="font-size:15px;line-height:1.8">{step.desc}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16">
        <a href="/process"
          class="font-sans inline-flex items-center gap-3 border border-brand-gold/50 text-brand-gold px-8 py-4 hover:bg-brand-gold hover:text-brand-navy transition-colors duration-300"
          style="font-size:14px;letter-spacing:0.1em">
          看完整流程與檢測儀器 →
        </a>
      </div>
    </div>
  </section>

  <!-- 兩大門市介紹 -->
  <section class="px-6 md:px-16 py-24 border-t border-brand-ink/10" style="background:#eee8da">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.22em">Two Locations</span>
        <h2 class="font-serif text-brand-ink" style="font-size:clamp(28px,4vw,48px);font-weight:300">新莊、板橋，挑離你近的那間</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- 新莊 -->
        <div class="bg-brand-paper border border-brand-ink/10 overflow-hidden">
          <picture>
            <source srcset="/images/store-xinzhuang.webp" type="image/webp" />
            <img src="/images/store-xinzhuang.webp" alt="能見度視覺中心 比泱驗光所 新莊門市" width="600" height="240" class="w-full h-60 object-cover" style="filter:sepia(6%)" />
          </picture>
          <div class="p-8">
            <span class="font-sans text-brand-ink-3 text-xs tracking-widest uppercase block mb-3" style="letter-spacing:0.18em">新莊店・2023年成立</span>
            <h3 class="font-serif text-brand-ink mb-1" style="font-size:22px;font-weight:400">能見度視覺中心 × 比泱驗光所</h3>
            <p class="text-brand-ink-3 mb-5" style="font-size:14px">臨床驗光・雙眼視覺・兒童近視追蹤</p>
            <div class="space-y-1 mb-6 text-brand-ink-2" style="font-size:15px">
              <p>📍 新北市新莊區中正路 419-1 號</p>
              <p>📞 <a href="tel:0222066700" class="hover:text-brand-ink transition-colors">02-2206-6700</a></p>
              <p class="text-brand-ink-3" style="font-size:13px">週一～六 11:00–21:00・週日 12:00–21:00・週四公休</p>
            </div>
            <a href="/xinzhuang/"
              class="font-sans inline-flex items-center gap-2 border border-brand-ink text-brand-ink px-5 py-2.5 hover:bg-brand-ink hover:text-brand-paper transition-colors duration-300"
              style="font-size:13px;letter-spacing:0.08em">
              門市詳情 →
            </a>
          </div>
        </div>

        <!-- 板橋 -->
        <div class="bg-brand-paper border border-brand-ink/10 overflow-hidden">
          <picture>
            <source srcset="/images/store-banqiao.webp" type="image/webp" />
