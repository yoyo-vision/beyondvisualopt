---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "高度近視適合選哪種鏡框？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "高度近視（-6.00D 以上）建議選擇「小鏡框」，因為鏡片研磨範圍越小，邊緣厚度越薄、重量越輕。鏡框越大，相同度數下鏡片邊緣厚度會增加 1–3mm，重量可能多出 5–10 克。YoYo 驗光師會根據你的度數和臉部結構，給出最適合的框型建議。"
          }
        },
        {
          "@type": "Question",
          "name": "Lindberg、ic! berlin 這類無螺絲鏡架壞了可以修嗎？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "可以。無螺絲、純鈦與彈片扣合結構的維修需要專門技術與工具，能見度精通 Lindberg、ic! berlin、Götti 等高端鏡架的精密調整與維修，Cartier、Chrome Hearts、Linda Farrow 等精品鏡架的調整與鏡片安裝也有豐富經驗。即使不是在本店購買的鏡架，也歡迎帶來評估。"
          }
        },
        {
          "@type": "Question",
          "name": "自己買的精品鏡框（Cartier、Chrome Hearts）可以帶來配鏡片嗎？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "可以。精品鏡架的鏡片安裝對框型結構與拆裝手法的要求比一般鏡框高，能見度有豐富的精品框配鏡經驗，會先評估框況，再依你的度數與框型建議合適的鏡片與加工方式。"
          }
        },
        {
          "@type": "Question",
          "name": "蔡司鏡片一定要配蔡司鏡架嗎？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "不一定。蔡司鏡片可以搭配任何品牌的鏡架，關鍵是鏡架的尺寸、前傾角（Pantoscopic Tilt）和頂點距離是否符合蔡司鏡片的設計參數。能見度為蔡司 Zeiss 簽約經銷商，所有鏡架調整均依照蔡司建議標準進行，確保鏡片光學性能完整發揮。"
          }
        },
        {
          "@type": "Question",
          "name": "鏡架多久需要調整一次？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "建議每 3–6 個月回店做一次微調，尤其是鼻托下滑、腳架外擴、或鏡架歪斜時。鏡架走位會改變光學中心對準位置，影響視覺清晰度。能見度提供所有品牌鏡架的免費精密調整服務。"
          }
        }
      ]
    }
  ]
};

const brands = [
  {
    name: 'ZEISS 蔡司',
    origin: '德國',
    type: '光學鏡片',
    badge: '蔡司 Zeiss 簽約經銷商',
    badgeColor: 'bg-brand-navy text-white',
    highlight: true,
    desc: '全球精密光學領導品牌，Individual² 個人化訂製鏡片根據你的配戴姿勢、瞳孔高度與頭部轉動習慣計算最佳視覺區域，是目前市面上客製化程度最高的漸進多焦鏡片。能見度為蔡司 Zeiss 簽約經銷商，具備完整的測量設備與鏡片配製能力。',
    tags: ['Individual² 個人化訂製', 'Digital Lens', 'DuraVision 抗反射', '超薄系列'],
  },
  {
    name: 'HOYA',
    origin: '日本',
    type: '光學鏡片',
    badge: 'HOYA 經銷商',
    badgeColor: 'bg-brand-navy text-white',
    highlight: true,
    desc: '日本光學大廠，鏡片以視野穩定與完整的度數範圍著稱，iD 系列漸進鏡片提供豐富的個人化選項。能見度為 HOYA 經銷商，可依你的用眼需求與預算，在蔡司與 HOYA 之間做客觀比較與選配。',
    tags: ['iD 漸進系列', '日本光學', '完整度數範圍', '高性價比'],
  },
  {
    name: '國際時尚精品鏡框',
    origin: '義大利・美國・法國',
    type: '經銷鏡框品牌',
    badge: '門市經銷',
    badgeColor: 'bg-brand-light text-brand-navy',
    highlight: false,
    desc: '從 Ray-Ban 的經典款到 OLIVER PEOPLES 的復古文青路線、EMPORIO ARMANI 與 BVLGARI 的精品質感、agnès b. 的法式簡約——門市提供正貨經銷鏡框，並以驗光數據協助你在風格與光學需求之間取得平衡。',
    tags: ['Ray-Ban', 'OLIVER PEOPLES', 'EMPORIO ARMANI', 'BVLGARI', 'agnès b.'],
  },
  {
    name: '日系與台灣工藝鏡框',
    origin: '日本・台灣・機能系列',
    type: '經銷鏡框品牌',
    badge: '門市經銷',
    badgeColor: 'bg-brand-light text-brand-navy',
    highlight: false,
    desc: 'MINAMOTO 源出自日本鯖江產地的細膩工藝，MASAKI MATSUSHIMA 帶著日本設計師的時尚語彙，Polaris 則是台灣自有的薄鋼工藝品牌——搭配 Maji、Orient、STEEPER、Sanjiaoti，涵蓋輕量、耐用、商務與日常的各種配戴需求。',
    tags: ['MINAMOTO 源（鯖江）', 'MASAKI MATSUSHIMA', 'Polaris 台灣薄鋼', 'Maji・Orient・STEEPER'],
  },
  {
    name: '高端鏡架維修調整・自帶鏡框配鏡',
    origin: 'Lindberg・ic! berlin・Cartier・Chrome Hearts 等',
    type: '專業維修服務',
    badge: '維修專長',
    badgeColor: 'bg-brand-light text-brand-navy',
    highlight: false,
    desc: 'Lindberg 的無螺絲純鈦結構、ic! berlin 的彈片扣合、Götti 的精密鈦工藝，到 Cartier、Chrome Hearts、Linda Farrow 等精品鏡架——本店雖非上述品牌代理門市，但長期為顧客做這類高端鏡架的精密調整、維修與鏡片安裝。自己收藏的精品框想配度數鏡片，歡迎帶來評估。',
    tags: ['無螺絲結構維修', '精品框鏡片安裝', '純鈦鏡架調整', '非代理・專精維修'],
  },
  {
    name: '精密鏡架調整服務',
    origin: '全品牌通用',
    type: '專業調整',
    badge: '免費提供',
    badgeColor: 'bg-green-100 text-green-800',
    highlight: false,
    desc: '不論任何品牌鏡架，能見度提供鼻托高度、腳架角度、鏡面傾斜角（Pantoscopic Tilt）的專業精密調整，確保光學中心精準對準瞳孔。鏡架走位是影響配鏡品質最容易被忽略的關鍵因素。',
    tags: ['鼻托高度調整', '傾斜角校正', '腳架張力調整', '全品牌適用'],
  },
];

const selectionGuide = [
  {
    need: '高度近視（-6.00D 以上）',
    recommendation: '選小鏡框 + 折射率 1.74 鏡片',
    reason: '鏡框越小、邊緣磨削面積越小，鏡片越薄越輕',
  },
  {
    need: '對鼻樑 / 耳朵壓迫敏感',
    recommendation: '超輕量鈦金屬或輕量日系鏡框',
    reason: '鏡架越輕，長時間配戴的壓迫感越低',
  },
  {
    need: '想要獨特風格 / 時尚感',
    recommendation: 'OLIVER PEOPLES、EMPORIO ARMANI 等設計師款',
    reason: '風格辨識度高、款式選擇多',
  },
  {
    need: '多焦點漸進鏡片配戴者',
    recommendation: '中等框深（≥ 28mm）鏡框',
    reason: '漸進鏡片需要足夠的垂直高度放置視覺分區',
  },
  {
    need: '對金屬過敏 / 敏感膚質',
    recommendation: '純鈦或醋酸纖維板料鏡框',
    reason: '純鈦不含鎳，醋酸纖維為植物基材',
  },
];

const faqs = [
  {
    q: '高度近視適合選哪種鏡框？',
    a: '高度近視（-6.00D 以上）建議選擇「小鏡框」——鏡片研磨範圍越小，邊緣厚度越薄、重量越輕。鏡框越大，相同度數下邊緣厚度可能多出 1–3mm，重量增加 5–10 克。YoYo 驗光師會根據你的度數與臉部結構，給出最適合的框型建議。',
  },
  {
    q: 'Lindberg、ic! berlin 這類無螺絲鏡架壞了可以修嗎？',
    a: '可以。無螺絲、純鈦與彈片扣合結構的維修需要專門技術與工具，能見度精通 Lindberg、ic! berlin、Götti 等高端鏡架的精密調整與維修，Cartier、Chrome Hearts、Linda Farrow 等精品鏡架的調整與鏡片安裝也有豐富經驗。即使不是在本店購買的鏡架，也歡迎帶來評估。',
  },
  {
    q: '自己買的精品鏡框（Cartier、Chrome Hearts）可以帶來配鏡片嗎？',
    a: '可以。精品鏡架的鏡片安裝對框型結構與拆裝手法的要求比一般鏡框高，能見度有豐富的精品框配鏡經驗，會先評估框況，再依你的度數與框型建議合適的鏡片與加工方式。',
  },
  {
    q: '蔡司鏡片一定要配蔡司鏡架嗎？',
    a: '不一定。蔡司鏡片可搭配任何品牌鏡架，關鍵是鏡架尺寸、前傾角與頂點距離是否符合蔡司鏡片設計參數。能見度為蔡司 Zeiss 簽約經銷商，所有鏡架調整均依照蔡司建議標準進行，確保光學性能完整發揮。',
  },
  {
    q: '鏡架多久需要調整一次？',
    a: '建議每 3–6 個月回店微調一次，尤其是鼻托下滑、腳架外擴或鏡架歪斜時。鏡架走位會改變光學中心對準位置，直接影響視覺清晰度。能見度提供所有品牌鏡架的免費精密調整服務。',
  },
];
---
<Layout
  title="鏡框品牌｜Ray-Ban・OLIVER PEOPLES・BVLGARI・MINAMOTO 源｜能見度視覺中心｜新莊板橋"
  description="Ray-Ban、OLIVER PEOPLES、BVLGARI、agnès b.、MINAMOTO 源等鏡框品牌經銷，並精通 Lindberg、ic! berlin、Cartier 等高端鏡架維修調整。能見度視覺中心新莊、板橋門市。"
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-brand-navy text-white py-20 px-4 text-center">
    <h1 class="text-4xl font-bold mb-4">鏡框品牌</h1>
    <p class="text-gray-300 text-lg max-w-2xl mx-auto">我們只選擇真正值得推薦的品牌——每一個都有其不可取代的配戴優勢，不是為了陳列而陳列。</p>
    <p class="text-brand-gold text-sm mt-4 tracking-wider">蔡司 Zeiss・HOYA 簽約經銷｜能見度視覺中心 新莊 × 板橋</p>
  </section>

  <!-- 品牌卡片 -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {brands.map(brand => (
        <div class={`rounded-2xl p-7 hover:shadow-lg transition-shadow flex flex-col ${brand.highlight ? 'border-2 border-brand-gold bg-brand-light' : 'border border-gray-200'}`}>
          <div class="flex justify-between items-start mb-3">
            <div>
              <h2 class="text-xl font-bold text-brand-navy">{brand.name}</h2>
              <p class="text-gray-400 text-xs mt-0.5">{brand.origin}｜{brand.type}</p>
            </div>
            <span class={`text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap ${brand.badgeColor}`}>{brand.badge}</span>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed flex-1">{brand.desc}</p>
          <div class="mt-4 pt-4 border-t border-gray-100 flex flex-wrap gap-2">
            {brand.tags.map(tag => (
              <span class="text-xs bg-white border border-gray-200 text-gray-500 px-2 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 選框指引 -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy text-center mb-3">如何選擇最適合你的鏡框？</h2>
      <p class="text-gray-500 text-sm text-center mb-10">從需求出發，不從品牌出發</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-brand-navy text-white">
              <th class="px-4 py-3 text-left font-semibold rounded-tl-lg">你的需求</th>
              <th class="px-4 py-3 text-left font-semibold">建議方向</th>
              <th class="px-4 py-3 text-left font-semibold rounded-tr-lg">原因</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            {selectionGuide.map(row => (
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 font-medium text-brand-navy">{row.need}</td>
                <td class="px-4 py-3 text-gray-700">{row.recommendation}</td>
                <td class="px-4 py-3 text-gray-500 text-xs">{row.reason}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-4 py-20">
    <h2 class="text-2xl font-bold text-brand-navy text-center mb-10">鏡框常見問題 FAQ</h2>
    <div class="space-y-6">
      {faqs.map((faq, i) => (
        <div class="border border-gray-200 rounded-xl p-6">
          <p class="font-bold text-brand-navy mb-2">Q{i + 1}. {faq.q}</p>
          <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy py-16 px-4 text-center text-white">
    <h2 class="text-2xl font-bold mb-4">不確定哪款鏡架最適合你？</h2>
    <p class="text-gray-300 mb-8 max-w-xl mx-auto">YoYo 驗光師會根據你的度數、臉部結構、配戴習慣與鏡片厚度需求，給你最精準的搭配建議——不是靠感覺，是靠數據。</p>
    <a href="/booking" class="bg-brand-gold text-white font-bold px-8 py-4 rounded-full hover:bg-brand-gold/90 transition-colors inline-block">
      預約鏡架試戴諮詢 →
    </a>
  </section>
</Layout>
