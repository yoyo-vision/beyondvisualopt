---
import Layout from '../layouts/Layout.astro';

const brands = [
  { name: 'ZEISS 蔡司', origin: '德國', type: '光學鏡片品牌', desc: '全球精密光學領導品牌，Individual² 個人化訂製鏡片根據你的配戴姿勢、瞳孔高度與頭部轉動習慣計算最佳視覺區域。', badge: '蔡司認證合作店' },
  { name: 'Lindberg', origin: '丹麥', type: '高端鏡架', desc: '全球最輕量的純鈦鏡架品牌，無螺絲設計、彈性記憶鈦材質，長期配戴無壓迫感，是高敏感膚質族群首選。', badge: '預約試戴' },
  { name: 'ic! berlin', origin: '德國', type: '設計鏡架', desc: '無螺絲彈片扣合技術，鏡架可快速拆裝維修。設計師款式每季更新，強調個人風格與機能並重。', badge: '德國設計' },
  { name: 'Face à Face', origin: '法國', type: '藝術鏡架', desc: '巴黎設計師品牌，以雕塑感框型與高飽和色彩聞名。適合想透過眼鏡表達個人風格的高端客群。', badge: '法國設計' },
  { name: 'Götti', origin: '瑞士', type: '輕量鈦架', desc: '瑞士工藝，極簡主義設計，醫療級純鈦材質。適合對鏡架重量與皮膚敏感度有高要求的配戴者。', badge: '瑞士工藝' },
  { name: '客製化調整鏡架', origin: '全品牌', type: '調整服務', desc: '任何品牌鏡架，我們提供鼻托高度、腳架角度、傾斜角的專業精密調整，確保光學中心精準對準。', badge: '免費調整' },
];
---
<Layout
  title="鏡框品牌｜蔡司鏡片認證合作 Lindberg ic! berlin｜能見度視覺中心 × 比泱驗光所 YoYo 驗光師"
  description="能見度視覺中心為蔡司鏡片認證合作店，同時代理 Lindberg、ic! berlin、Götti 等高端鏡架。YoYo 驗光師協助配搭高度近視眼鏡最適鏡框。新莊、板橋門市。"
>
  <section class="bg-brand-navy text-white py-20 px-4 text-center">
    <h1 class="text-4xl font-bold mb-4">鏡框品牌</h1>
    <p class="text-gray-300 text-lg max-w-2xl mx-auto">我們只選擇真正值得推薦的品牌，每一個都有其不可取代的配戴優勢。</p>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {brands.map(brand => (
        <div class="border border-gray-200 rounded-2xl p-6 hover:shadow-lg transition-shadow">
          <div class="flex justify-between items-start mb-3">
            <div>
              <h2 class="text-xl font-bold text-brand-navy">{brand.name}</h2>
              <p class="text-gray-400 text-sm">{brand.origin}｜{brand.type}</p>
            </div>
            <span class="bg-brand-light text-brand-navy text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap">{brand.badge}</span>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed">{brand.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-brand-light py-16 px-4 text-center">
    <h2 class="text-2xl font-bold text-brand-navy mb-4">不確定哪款鏡架最適合你的臉型？</h2>
    <p class="text-gray-600 mb-8">YoYo 驗光師會根據你的臉部結構、配戴習慣與鏡片厚度需求，給你最精準的建議。</p>
    <a href="/booking" class="bg-brand-navy text-white font-bold px-8 py-4 rounded-full hover:bg-brand-navy/90 transition-colors inline-block">
      預約鏡架試戴諮詢
    </a>
  </section>
</Layout>
