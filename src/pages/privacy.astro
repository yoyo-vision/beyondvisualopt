---
import Layout from '../layouts/Layout.astro';

// 隱私權政策頁：個資法合規，E-E-A-T 信任加分。內容以事實為主，無行銷宣稱。
const sections = [
  {
    h: '一、適用範圍',
    body: '本政策適用於 beyondvisualopt.com 網站，以及您透過本站進行的線上預約與聯繫。當您前往第三方網站或服務（如 Google、LINE 及社群平台），其個資處理適用各該服務之隱私權政策，不在本政策範圍內。',
  },
  {
    h: '二、我們蒐集的個人資料',
    list: [
      '線上預約資訊：姓名、電話、偏好門市、預約時段、視覺需求描述。',
      '您主動聯繫時提供之資訊。',
      '網站瀏覽數據：透過 GA4 與 Cookie 蒐集之去識別化統計數據（如造訪頁面、停留時間、裝置類型），以不易識別特定個人之形式處理。',
    ],
  },
  {
    h: '三、蒐集目的與利用方式',
    body: '我們基於下列特定目的蒐集及利用您的個人資料：預約安排、視覺分析服務、配戴追蹤與售後服務、回應諮詢、網站流量分析。僅於上述目的之必要範圍內利用，不會出售、出租或提供予與服務無關之第三人。',
  },
  {
    h: '四、利用之期間、地區、對象及方式',
    list: [
      '期間：至前述蒐集目的消失，或您請求停止利用／刪除時為止（法令另有保存期間規定者，依其規定）。',
      '地區：您直接提供之預約與聯繫個資儲存於台灣境內；惟透過 GA4、LINE 等第三方服務所生之數據，可能由該等服務商於台灣境外之伺服器處理。',
      '對象：限本公司兩門市之驗光人員及必要營運人員；及前述第三方分析／通訊服務於必要範圍內之處理。',
      '方式：以電子檔案及／或紙本方式，於前述目的範圍內處理及利用。',
    ],
  },
  {
    h: '五、您提供個資之權益說明',
    body: '您可自由選擇是否提供個人資料。惟若不提供預約所需之必要資訊（如姓名、電話），我們將無法為您完成預約安排或提供相對應之服務。',
  },
  {
    h: '六、Cookie 與網站分析',
    body: '本站使用 Cookie 與 GA4 進行流量分析與體驗優化。您可透過瀏覽器設定拒絕或刪除 Cookie，惟部分功能可能因此受影響。本站嵌入之第三方服務，另依各該服務之條款與政策處理。',
  },
  {
    h: '七、您（當事人）的權利',
    list: [
      '查詢或請求閱覽。',
      '請求製給複製本。',
      '請求補充或更正。',
      '請求停止蒐集、處理或利用。',
      '請求刪除。',
    ],
    after: '您可透過下方聯絡方式提出，我們將於法定期間內回覆處理；行使前述權利不影響您已同意之其他約定。',
  },
  {
    h: '八、未成年人個人資料',
    body: '若您為未成年人，請於法定代理人知悉並同意後提供個人資料；為未成年人（如兒童視力追蹤對象）提供個資者，視為已取得法定代理人同意。',
  },
  {
    h: '九、資料安全',
    body: '我們採取合理之技術與管理措施保護您的個人資料。惟網路傳輸與儲存無法保證絕對安全；如發生個資外洩之虞，我們將依法通知並處理。',
  },
  {
    h: '十、政策修訂',
    body: '本政策如有修訂，將於本頁公告更新，並註記最後更新日期。',
  },
];
---
<Layout
  title="隱私權政策｜能見度視覺中心 新莊板橋"
  description="能見度視覺中心 × 比泱驗光所隱私權政策：說明官網蒐集之個人資料類別、蒐集目的、利用方式，以及您依個人資料保護法享有的權利。"
  enPath="/en/privacy"
>
  <section class="bg-brand-navy text-white py-20 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <span class="font-sans text-brand-gold tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.22em">Privacy Policy</span>
      <h1 class="font-serif text-white mb-4" style="font-size:clamp(28px,4vw,44px);font-weight:300">隱私權政策</h1>
      <p class="text-white/60" style="font-size:15px">最後更新：2026 年 7 月 15 日</p>
    </div>
  </section>

  <section class="px-6 md:px-16 py-16" style="background:#f7f3ec">
    <div class="max-w-3xl mx-auto space-y-10">
      <p class="text-brand-ink-2" style="font-size:16px;line-height:1.9">
        能見度視覺中心（以下簡稱「本中心」）尊重並保護每一位訪客與顧客的個人資料。本政策說明我們如何蒐集、利用與保護您的個人資料，以及您依法享有的權利。
      </p>

      {sections.map(s => (
        <div>
          <h2 class="font-serif text-brand-navy mb-3" style="font-size:20px;font-weight:600">{s.h}</h2>
          {s.body && <p class="text-brand-ink-2" style="font-size:16px;line-height:1.9">{s.body}</p>}
          {s.list && (
            <ul class="space-y-2 mt-2">
              {s.list.map(item => (
                <li class="flex items-start gap-2 text-brand-ink-2" style="font-size:16px;line-height:1.8">
                  <span class="text-brand-gold mt-1 shrink-0">✦</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          )}
          {s.after && <p class="text-brand-ink-2 mt-3" style="font-size:16px;line-height:1.9">{s.after}</p>}
        </div>
      ))}

      <div class="border-t border-brand-ink/15 pt-8">
        <h2 class="font-serif text-brand-navy mb-3" style="font-size:20px;font-weight:600">十一、聯絡我們</h2>
        <p class="text-brand-ink-2 mb-4" style="font-size:16px;line-height:1.9">
          如對本政策或您的個人資料有任何疑問，或欲行使上述權利，歡迎透過官方 LINE 或以下門市與我們聯繫：
        </p>
        <div class="space-y-3 text-brand-ink-2" style="font-size:15px;line-height:1.8">
          <p><strong>新莊店（比泱驗光所）</strong><br />新北市新莊區中正路419-1號｜<a href="tel:0222066700" class="text-brand-navy hover:text-brand-gold transition-colors">02-2206-6700</a></p>
          <p><strong>板橋店（能見度驗光所）</strong><br />新北市板橋區雙十路二段47巷28號｜<a href="tel:0222531246" class="text-brand-navy hover:text-brand-gold transition-colors">02-2253-1246</a></p>
        </div>
      </div>
    </div>
  </section>
</Layout>
