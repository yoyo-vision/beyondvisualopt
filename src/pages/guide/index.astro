---
import Layout from '../../layouts/Layout.astro';

// 完整指南（支柱頁）
const GUIDES = [
  {
    href: '/guide/progressive-lens/',
    tag: '老花・多焦點',
    title: '多焦點（漸進）鏡片完整指南',
    desc: '原理、老花 4 種方案比較、鏡片等級選擇、暈眩排查與適應方法——多焦點最常見的疑問一次講清楚。',
  },
  {
    href: '/guide/children-myopia/',
    tag: '兒童視力',
    title: '兒童近視控制完整指南',
    desc: '近視為什麼會加深、控制方法比較、家長最常犯的錯誤，以及定期追蹤為什麼是關鍵。',
  },
  {
    href: '/guide/high-myopia/',
    tag: '高度近視',
    title: '高度近視配鏡完整指南',
    desc: '600 度以上配鏡的光學差異、折射率選擇、鏡框原則，以及框架與隱形眼鏡的取捨。',
  },
  {
    href: '/guide/lens-brands/',
    tag: '鏡片品牌',
    title: '鏡片品牌選購完整指南',
    desc: '蔡司、HOYA、NIKON、依視路四大品牌定位比較，怎麼依需求選，以及為什麼「等級」比「品牌」更關鍵。',
  },
  {
    href: '/guide/digital-eye-strain/',
    tag: '數位疲勞',
    title: '螢幕族視覺疲勞完整指南',
    desc: '長時間看螢幕為什麼眼睛累、症狀自我檢查、用眼習慣與鏡片方案——寫給工程師、醫師、上班族。',
  },
  {
    href: '/guide/choose-optician/',
    tag: '在地選購',
    title: '新北配眼鏡完整指南',
    desc: '驗光所 vs 眼鏡行差在哪、怎麼判斷一家好的驗光所、常見配鏡地雷，以及新莊、板橋在地選擇。',
  },
];
---
<Layout
  title="視覺健康完整指南｜多焦點・兒童近視・高度近視｜能見度視覺中心 新莊板橋"
  description="YoYo 驗光師撰寫的三大完整指南：多焦點鏡片、兒童近視控制、高度近視配鏡。一頁看懂原理、方案比較與驗配重點。新莊、板橋能見度視覺中心。"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-navy to-[#0f1e33] text-white py-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-gold font-sans font-semibold tracking-widest uppercase mb-5" style="font-size:13px;letter-spacing:0.2em">完整指南</p>
      <h1 class="font-serif text-white leading-tight mb-6" style="font-size:clamp(28px,4.5vw,46px);font-weight:300">
        一頁講透一個主題的<br /><span class="text-brand-gold">視覺健康指南</span>
      </h1>
      <p class="text-white/70 max-w-2xl mx-auto" style="font-size:17px;line-height:1.85">
        由 YoYo 驗光師撰寫，依據臨床驗配實務。每份指南整合該主題的所有文章，從原理到方案選擇一次看懂。
      </p>
    </div>
  </section>

  <!-- 指南列表 -->
  <section class="px-6 md:px-16 py-16" style="background:#f7f3ec">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
      {GUIDES.map(g => (
        <a href={g.href} class="bg-white rounded-2xl p-8 border border-brand-ink/5 hover:border-brand-gold transition-colors group flex flex-col">
          <span class="font-sans text-brand-gold font-semibold tracking-widest uppercase mb-4" style="font-size:11px;letter-spacing:0.18em">{g.tag}</span>
          <h2 class="font-serif text-brand-navy mb-4 group-hover:text-brand-gold transition-colors" style="font-size:20px;font-weight:600;line-height:1.5">{g.title}</h2>
          <p class="text-brand-ink-3 flex-1" style="font-size:14px;line-height:1.75">{g.desc}</p>
          <span class="font-sans text-brand-gold mt-6" style="font-size:14px">閱讀指南 →</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
