---
import Layout from '../../layouts/Layout.astro';

// 完整指南（支柱頁）
const GUIDES = [
  {
    href: '/guide/progressive-lens/',
    tag: '老花・多焦點',
    title: '多焦點（漸進）鏡片完整指南',
    desc: '原理、老花 4 種方案比較、鏡片等級選擇、暈眩排查與適應方法——多焦點最常見的疑問一次講清楚。',
  },
  {
    href: '/guide/children-myopia/',
    tag: '兒童視力',
    title: '兒童近視追蹤完整指南',
    desc: '近視為什麼會加深、驗光所與眼科怎麼分工、家長最常犯的錯誤，以及定期追蹤為什麼是關鍵。',
  },
  {
    href: '/guide/high-myopia/',
    tag: '高度近視',
    title: '高度近視配鏡完整指南',
    desc: '600 度以上配鏡的光學差異、折射率選擇、鏡框原則，以及框架與隱形眼鏡的取捨。',
  },
  {
    href: '/guide/lens-brands/',
    tag: '鏡片品牌',
    title: '鏡片品牌選購完整指南',
    desc: '蔡司、HOYA、NIKON、依視路四大品牌定位比較，怎麼依需求選，以及為什麼「等級」比「品牌」更關鍵。',
  },
  {
    href: '/guide/digital-eye-strain/',
    tag: '數位疲勞',
    title: '螢幕族視覺疲勞完整指南',
    desc: '長時間看螢幕為什麼眼睛累、症狀自我檢查、用眼習慣與鏡片方案——寫給工程師、醫師、上班族。',
  },
  {
    href: '/guide/choose-optician/',
    tag: '在地選購',
    title: '新北配眼鏡完整指南',
    desc: '驗光所 vs 眼鏡行差在哪、怎麼判斷一家好的驗光所、常見配鏡地雷，以及新莊、板橋在地選擇。',
  },
  {
    href: '/guide/eye-doctor-or-optometrist/',
    tag: '就醫分流',
    title: '掛眼科還是找驗光所？症狀分流指南',
    desc: '我們不是眼科——哪些症狀請直接就醫（紅痛、視力驟降、飛蚊暴增）、哪些狀況驗光所就能處理（度數變化、眼鏡不適、配鏡評估），30 秒分流表誠實講清楚。',
  },
  {
    href: '/guide/byo-frame-lenses/',
    tag: '自帶框配鏡片',
    title: '自帶鏡框配鏡片完整指南',
    desc: '網購框、精品框、舊框、二手古董框都歡迎帶來配鏡片——框況評估、風險告知、鏡片＋固定加工費透明計價，量測標準與配整副眼鏡相同。',
  },
  {
    href: '/guide/frames/',
    tag: '鏡框選購',
    title: '鏡框選購完整指南',
    desc: '臉型怎麼配框、板材金屬鈦材質比較、鏡框尺寸怎麼看合適，以及鏡框如何配合鏡片需求。',
  },
  {
    href: '/guide/optical-basics/',
    tag: '視光小百科',
    title: '視光小百科',
    desc: '度數、屈光度、瞳距、頂點距離、折射率、非球面、鍍膜、藍光、偏光、變色——驗光單與鏡片的專業名詞白話拆解。',
  },
  {
    href: '/guide/aniseikonia/',
    tag: '雙眼視覺',
    title: '不等像完整指南',
    desc: '兩眼度數差很多、看久頭暈、字會跳、立體感變差？從不等像原理、症狀自我檢核，到配鏡怎麼減少影像大小差異一次講清楚。',
  },
  {
    href: '/guide/rgp-contact-lens/',
    tag: '硬式隱形眼鏡',
    title: 'RGP 硬式隱形眼鏡完整指南',
    desc: 'RGP 是什麼、和軟式與角膜塑形（OK 鏡）差在哪、誰可能適合、驗配流程與安全須知——日戴型 RGP 一頁看懂。',
  },
];
---
<Layout
  title="視覺健康完整指南｜多焦點・兒童近視・高度近視｜能見度視覺中心 新莊板橋"
  description="YoYo 驗光師撰寫的八大視覺健康指南：多焦點、兒童近視、高度近視、鏡片品牌、螢幕疲勞、鏡框選購一次看懂原理與驗配重點。能見度視覺中心 新莊板橋。"
  enPath="/en/guide"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-navy to-[#0f1e33] text-white py-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-gold font-sans font-semibold tracking-widest uppercase mb-5" style="font-size:13px;letter-spacing:0.2em">完整指南</p>
      <h1 class="font-serif text-white leading-tight mb-6" style="font-size:clamp(28px,4.5vw,46px);font-weight:300">
        一頁講透一個主題的<br /><span class="text-brand-gold">視覺健康指南</span>
      </h1>
      <p class="text-white/70 max-w-2xl mx-auto" style="font-size:17px;line-height:1.85">
        由 YoYo 驗光師撰寫，依據臨床驗配實務。每份指南整合該主題的所有文章，從原理到方案選擇一次看懂。
      </p>
    </div>
  </section>

  <!-- 指南列表 -->
  <section class="px-6 md:px-16 py-16" style="background:#f7f3ec">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
      {GUIDES.map(g => (
        <a href={g.href} class="bg-white rounded-2xl p-8 border border-brand-ink/5 hover:border-brand-gold transition-colors group flex flex-col">
          <span class="font-sans text-brand-gold font-semibold tracking-widest uppercase mb-4" style="font-size:11px;letter-spacing:0.18em">{g.tag}</span>
          <h2 class="font-serif text-brand-navy mb-4 group-hover:text-brand-gold transition-colors" style="font-size:20px;font-weight:600;line-height:1.5">{g.title}</h2>
          <p class="text-brand-ink-3 flex-1" style="font-size:14px;line-height:1.75">{g.desc}</p>
          <span class="font-sans text-brand-gold mt-6" style="font-size:14px">閱讀指南 →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- 作者權威帶：這些指南出自誰、憑什麼可信（E-E-A-T Authoritativeness，連向有 Person schema 的作者頁） -->
  <section class="px-6 md:px-16 py-16" style="background:#eee8da">
    <div class="max-w-4xl mx-auto">
      <div class="bg-white border border-brand-ink/8 p-8 md:p-10 flex flex-col md:flex-row gap-8 items-center">
        <img src="/images/yoyo-optometrist.webp" alt="YoYo 驗光師 鄭家侑 能見度視覺中心 比泱驗光所"
          width="120" height="120" class="w-28 h-28 rounded-full object-cover object-top flex-shrink-0" loading="lazy" />
        <div class="text-center md:text-left">
          <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-2" style="font-size:12px;letter-spacing:0.18em">關於作者</span>
          <h2 class="font-serif text-brand-navy mb-2" style="font-size:22px;font-weight:600">鄭家侑（YoYo）驗光師</h2>
          <p class="text-brand-ink-2 mb-4" style="font-size:15px;line-height:1.85">
            中華民國執照驗光師（驗師字第 003309 號），能見度視覺中心 × 比泱驗光所主理。這裡的每一份指南都由 YoYo 依臨床驗配實務撰寫——寫的是每天在驗光室裡真正遇到、真正處理的驗配與視覺問題，不是網路資料的整理轉貼。
          </p>
          <a href="/author/yoyo/" class="font-sans inline-flex items-center gap-2 text-brand-navy font-semibold hover:text-brand-gold transition-colors" style="font-size:14px">認識 YoYo 驗光師 →</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
