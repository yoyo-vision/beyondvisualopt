---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 本指南的主題聚落文章（依閱讀順序排列）
const CLUSTER_SLUGS = [
  'children-myopia-tracking-xinzhuang',
  'myopia-getting-worse-truth',
  'optometry-vs-ophthalmology',
  'common-optometry-mistakes',
];
const allPosts = await getCollection('blog');
const clusterPosts = CLUSTER_SLUGS
  .map(slug => allPosts.find(p => p.slug === slug))
  .filter(Boolean);

const canonicalUrl = 'https://beyondvisualopt.com/guide/children-myopia/';

// 指南頁 FAQ（與聚落文章互補，不重複）
const faqs = [
  {
    q: '兒童近視追蹤有什麼用？度數還能倒退嗎？',
    a: '先講清楚：眼軸一旦拉長就不會縮回，度數無法倒退。追蹤的價值在於掌握趨勢——每 3–6 個月記錄度數與眼軸變化，在加深速度改變時及時調整配鏡方案與用眼習慣，而不是一年後才發現又深了 100 度。離焦設計鏡片的配適與追蹤是驗光人員可以做的事；是否需要藥物等醫療介入，請由眼科醫師評估。搭配每天 2 小時戶外活動與定期追蹤，才是完整的做法。',
  },
  {
    q: '孩子幾歲開始做近視追蹤？',
    a: '越早越好。近視加深最快的黃金期是 8–14 歲，6 歲以上、每年加深超過 50 度的孩子就建議開始每 3–6 個月定期追蹤。6 歲以下的初次視力篩檢建議先由眼科醫師進行（含散瞳驗光，屬醫療行為）。追蹤一般建議持續到 18–20 歲眼軸發育趨於穩定為止——不是做幾年就停，而是整個發育期都掌握趨勢。',
  },
  {
    q: '離焦鏡片和一般鏡片差在哪裡？',
    a: '一般鏡片只做一件事：把焦點對準視網膜中心，讓孩子看得清楚。離焦設計鏡片則在矯正中心視力的同時，於鏡片周邊加入特殊光學結構——例如蔡司 MyoCare 採 C.A.R.E.® 技術，在鏡片表面設計近乎隱形的同心柱狀環，交替排列離焦與矯正區域。外觀上兩者幾乎看不出差別，差異在光學設計，而配鏡高度與光學中心對準的精度，直接影響離焦區是否落在正確位置。這類鏡片是否適合你的孩子，建議搭配眼科醫師的檢查一起評估。',
  },
  {
    q: '新莊哪裡可以做兒童近視追蹤？',
    a: '能見度視覺中心新莊店（比泱驗光所，新北市新莊區中正路419-1號，02-2206-6700）是兒童近視追蹤的主力服務門市，提供眼軸長測量、度數變化紀錄、離焦設計軟式隱形眼鏡驗配與蔡司 MyoCare 評估，由驗光人員每 3–6 個月定期追蹤。板橋地區可洽能見度眼鏡行板橋店（02-2253-1246）。若追蹤過程發現需要藥物評估（如低濃度阿托品）或眼底檢查，會依《驗光人員法》協助轉介眼科醫師。',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": canonicalUrl,
      "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
      "url": canonicalUrl,
      "headline": "兒童近視追蹤完整指南：加深原因、照護分工、家長常犯錯誤與追蹤機制",
      "description": "近視為什麼會一直加深？從眼軸不可逆的原理、驗光所與眼科的照護分工、家長最常犯的錯誤，到 3–6 個月定期追蹤機制，YoYo 驗光師一頁講透兒童近視追蹤。新莊、板橋服務。",
      "image": "https://beyondvisualopt.com/og-image.jpg",
      "inLanguage": "zh-TW",
      "articleSection": "完整指南",
      "author": {
        "@type": "Person",
        "@id": "https://beyondvisualopt.com/author/yoyo/#person",
        "name": "鄭家侑（YoYo）",
        "url": "https://beyondvisualopt.com/author/yoyo/"
      },
      "publisher": { "@id": "https://beyondvisualopt.com/#organization" }
    },
    {
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
  ],
};
---
<Layout
  title="兒童近視追蹤完整指南｜孩子近視一直加深怎麼辦｜新莊板橋兒童近視追蹤"
  description="孩子近視一直加深怎麼辦？從眼軸不可逆的原理、離焦鏡片怎麼看、家長最常犯的錯誤到 3–6 個月追蹤機制，YoYo 驗光師一頁講透。新莊、板橋能見度視覺中心。"
  enPath="/en/guide/children-myopia"
  schema={schema}
>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-navy to-[#0f1e33] text-white py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-gold font-sans font-semibold tracking-widest uppercase mb-5" style="font-size:13px;letter-spacing:0.2em">完整指南</p>
      <h1 class="font-serif text-white leading-tight mb-7" style="font-size:clamp(30px,4.5vw,52px);font-weight:300">
        兒童近視追蹤<br /><span class="text-brand-gold">完整指南</span>
      </h1>
      <p class="text-white/70 max-w-2xl mx-auto" style="font-size:18px;line-height:1.85">
        為什麼會加深、驗光所與眼科怎麼分工、家長最常踩的坑、追蹤機制怎麼運作——這一頁把兒童近視最讓家長焦慮的問題一次講清楚。由 YoYo 驗光師撰寫，依據臨床驗光實務與國際研究，不是恐嚇文。
      </p>
    </div>
  </section>

  <!-- TL;DR 3秒重點（GEO：answer-first） -->
  <section class="px-6 md:px-16 py-10" style="background:#eee8da">
    <div class="max-w-4xl mx-auto">
      <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.2em">3 秒重點</span>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-3 text-brand-ink-2" style="font-size:16px;line-height:1.7"><span class="text-brand-gold mt-1 shrink-0">✦</span><span>近視的本質是眼軸拉長，眼軸一旦變長就不可逆、度數無法倒退；正因如此，及早、每 3–6 個月定期掌握孩子的度數與眼軸變化趨勢格外重要，才能在度數加深加速時，儘早與眼科醫師討論合適的介入方式。</span></li>
        <li class="flex items-start gap-3 text-brand-ink-2" style="font-size:16px;line-height:1.7"><span class="text-brand-gold mt-1 shrink-0">✦</span><span>台灣法規分工明確：離焦鏡片配適與定期追蹤是驗光人員的工作；藥物與散瞳屬醫療行為，須由眼科醫師評估與執行。</span></li>
        <li class="flex items-start gap-3 text-brand-ink-2" style="font-size:16px;line-height:1.7"><span class="text-brand-gold mt-1 shrink-0">✦</span><span>每天 2 小時戶外活動是常見建議；鏡片、戶外、用眼習慣三者是相乘關係，不是互相替代。</span></li>
        <li class="flex items-start gap-3 text-brand-ink-2" style="font-size:16px;line-height:1.7"><span class="text-brand-gold mt-1 shrink-0">✦</span><span>追蹤機制才是核心：每 3–6 個月記錄度數與眼軸變化，才能在加深加速時及時調整，而不是一年後才發現又深了。</span></li>
      </ul>
    </div>
  </section>

  <!-- 快速導覽 -->
  <section class="px-6 py-10 border-b border-brand-ink/8" style="background:#f7f3ec">
    <div class="max-w-4xl mx-auto flex flex-wrap gap-3 justify-center">
      {[
        { label: '近視為什麼會加深', href: '#why' },
        { label: '照護分工與方法', href: '#methods' },
        { label: '家長常犯的錯誤', href: '#mistakes' },
        { label: '定期追蹤機制', href: '#tracking' },
        { label: '常見問題', href: '#faq' },
      ].map(item => (
        <a href={item.href} class="font-sans bg-white border border-brand-ink/10 text-brand-ink-2 px-4 py-2 rounded-full hover:border-brand-gold hover:text-brand-gold transition-colors" style="font-size:13px">{item.label}</a>
      ))}
    </div>
  </section>

  <!-- 近視為什麼會加深 -->
  <section id="why" class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-8" style="font-size:clamp(24px,3.5vw,36px);font-weight:400">近視的本質是眼軸拉長——而且拉長了就回不去</h2>
      <div class="space-y-5 text-brand-ink-2" style="font-size:17px;line-height:1.85">
        <p>「不是怕孩子戴眼鏡，是怕他每年度數一直加深，感覺控制不住。」這是門市最常聽到的一句話。你的擔心是對的，但焦慮要放在對的地方。</p>
        <p>近視的根本原因是<strong>眼軸（眼球前後徑）過長</strong>，光線焦點落在視網膜前方。眼軸一旦延長就無法縮回——這是不可逆的結構性改變。所以近視照護的重點從來不是「讓度數倒退」，而是<strong>及早掌握眼軸與度數的變化趨勢</strong>，在度數加深加速時，儘早與眼科醫師討論合適的介入方式。</p>
        <p><strong>為什麼要在意？</strong>高度近視（-6.00D 以上）未來發生視網膜剝離、黃斑部病變、青光眼的風險顯著較高（依國健署與眼科醫學會公開衛教資料）。台灣是全球近視盛行率最高的地區之一：小一約 5–10%，小六已達 55–65%，高中畢業超過 85%（盛行率參考國民健康署學齡兒童視力監測）。而加深速度最快的階段是 <strong>8–14 歲</strong>——這個階段的定期追蹤與照護最重要。</p>
        <p>造成眼軸持續延長的三個主因：<strong>近距離用眼過久</strong>（每天超過 3–4 小時盯著手機、書本、平板，睫狀肌長期緊縮）、<strong>戶外活動不足</strong>（每天 2 小時戶外活動是<a href="https://www.hpa.gov.tw/Pages/List.aspx?nodeid=45" target="_blank" rel="noopener noreferrer" class="text-brand-gold underline">衛福部國民健康署視力保健</a>等單位的常見建議，相關研究顯示自然光環境與眼軸發展有觀察上的關聯）、<strong>缺乏定期追蹤</strong>（不知道眼軸有沒有在加長，就無法在對的時機調整方案）。另外，父母雙方都近視的孩子，近視風險顯著較高（依公開衛教資料）——遺傳改變不了，但更該提早追蹤。</p>
      </div>
    </div>
  </section>

  <!-- 照護分工比較 -->
  <section id="methods" class="px-6 md:px-16 py-20 bg-white">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-4" style="font-size:clamp(24px,3.5vw,36px);font-weight:400">近視照護怎麼分工：哪些是驗光所能做的，哪些要找眼科</h2>
      <p class="text-brand-ink-3 mb-10" style="font-size:16px;line-height:1.8">台灣法規下的分工很明確：離焦鏡片配適與定期追蹤是驗光人員的工作；藥物與散瞳屬醫療行為，需由眼科醫師處方。分工合作，不是二選一。</p>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse" style="font-size:15px">
          <thead>
            <tr class="bg-brand-navy text-white">
              <th class="text-left px-5 py-4 font-semibold">方法</th>
              <th class="text-left px-5 py-4 font-semibold">適合對象</th>
              <th class="text-left px-5 py-4 font-semibold">誰負責</th>
            </tr>
          </thead>
          <tbody class="text-brand-ink-2">
            {[
              ['戶外活動 2 小時/天', '所有孩子，零成本的第一步', '家長（日常執行）'],
              ['蔡司 MyoCare（框架離焦鏡片）', '框架形式的學童離焦設計鏡片', '驗光人員配適與追蹤'],
              ['離焦設計軟式隱形眼鏡（日拋）', '需驗光人員評估；十五歲以下須眼科醫師指導下驗配', '驗光人員配適與追蹤'],
              ['低濃度阿托品', '經醫師評估適合藥物介入的孩子', '眼科醫師處方（醫療行為）'],
            ].map(row => (
              <tr class="border-b border-brand-ink/8">
                {row.map((cell, i) => (
                  <td class={`px-5 py-4 align-top ${i === 0 ? 'font-semibold text-brand-navy' : ''}`}>{cell}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <blockquote class="border-l-2 border-brand-gold pl-5 text-brand-ink-3 mt-8" style="font-size:16px;line-height:1.8">
        各方案是否適合個別孩子，需經現場評估；涉及藥物與醫療處置，請諮詢眼科醫師。YoYo 驗光師的原則：再好的鏡片，孩子不願意配合就沒有效果——先找出孩子真正願意戴、家庭能持續執行的組合，而不是推薦最貴的方案。
      </blockquote>
    </div>
  </section>

  <!-- 家長常犯的錯誤 -->
  <section id="mistakes" class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-8" style="font-size:clamp(24px,3.5vw,36px);font-weight:400">家長最常犯的 4 個錯誤，每一個都在幫近視加速</h2>
      <div class="space-y-6">
        {[
          { title: '① 怕度數加深，不敢讓孩子戴眼鏡', desc: '「戴眼鏡會依賴、度數越戴越深」是流傳幾十年的迷思。近視加深的原因是眼軸拉長，與戴不戴眼鏡無關。發育期的視覺系統需要清晰的影像刺激，部分研究顯示長期欠矯（度數不足或不配鏡）反而與近視加深有相關性——用模糊視力硬撐，是反效果。', action: '該配就配，配足但不過矯' },
          { title: '② 用十分鐘快速驗光的度數直接配鏡', desc: '兒童的睫狀肌調節力強，長時間近距離用眼後處於緊繃狀態，電腦驗光值往往偏深。直接沿用會造成過矯——有研究認為過矯與近視加深有關聯。完整的主客觀驗光需要充分放鬆調節力再測量，特定情況下眼科醫師會建議散瞳驗光（屬醫療行為，需由眼科醫師執行）。', action: '選擇有完整放鬆調節流程的驗光' },
          { title: '③ 配了眼鏡，卻沒改用眼習慣', desc: '離焦鏡片不是護身符。配了鏡片但孩子每天近距離用眼還是超過 3–4 小時、戶外時間趨近於零，眼軸照樣拉長。近距離用眼每 20–30 分鐘休息 20 秒看 6 公尺遠、閱讀距離維持 33 公分以上、每天 2 小時戶外——鏡片與習慣是相乘，不是替代。', action: '鏡片＋戶外＋用眼習慣三管齊下' },
          { title: '④ 配一次就結束，沒有回來追蹤', desc: '沒有追蹤，就不知道現在的方案有沒有效。度數會受調節狀態影響，眼軸長才是反映眼球發育的客觀指標。每 3–6 個月追蹤一次，才能在孩子加深加速的時候及時調整方案，而不是一年後才發現又深了 100 度。', action: '把 3–6 個月回診寫進行事曆' },
        ].map(item => (
          <div class="bg-white border border-brand-ink/8 rounded-2xl p-7">
            <h3 class="font-serif text-brand-navy mb-3" style="font-size:19px;font-weight:600">{item.title}</h3>
            <p class="text-brand-ink-2 mb-3" style="font-size:16px;line-height:1.8">{item.desc}</p>
            <p class="font-sans text-brand-gold" style="font-size:14px">→ {item.action}</p>
          </div>
        ))}
      </div>
      <p class="text-brand-ink-2 mt-8" style="font-size:16px;line-height:1.8">
        想知道還有哪些驗光環節常被省略？看這篇：<a href="/blog/common-optometry-mistakes/" class="text-brand-gold underline">配眼鏡常見的 5 個驗光誤區</a>
      </p>
    </div>
  </section>

  <!-- 定期追蹤機制 -->
  <section id="tracking" class="px-6 md:px-16 py-20" style="background:#1a2f4e">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-white mb-4" style="font-size:clamp(24px,3.5vw,36px);font-weight:300">定期追蹤，才是兒童視力照護真正的核心</h2>
      <p class="text-white/60 mb-10" style="font-size:16px;line-height:1.8">鏡片只是工具，追蹤才是機制。沒有每 3–6 個月的數據，你永遠不知道現在的方案對你的孩子有沒有用。能見度視覺中心的兒童近視追蹤包含以下項目。</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-6">
        {[
          ['眼軸長測量（每 3–6 個月）', '眼軸變化才是眼球發育的客觀指標，比度數更能反映真實趨勢——度數會受調節狀態影響，眼軸不會'],
          ['度數變化紀錄與趨勢分析', '單次數據沒有意義，連續紀錄才能看出加深速度是在減緩還是加速，作為方案調整依據'],
          ['完整主客觀驗光（放鬆調節力）', '兒童調節力強、驗光值容易偏深，充分放鬆後測量才不會過矯——過矯本身就與近視加深有關聯'],
          ['離焦鏡片配適與光學中心確認', '離焦區的位置以毫米為單位，鏡架滑落或光學中心偏移，離焦設計就打了折扣'],
          ['兒童鏡架配適調整', '輕盈服貼、不易滑落、耐摔的鏡架，孩子才願意天天戴——戴得住，配鏡才有意義'],
          ['異常狀況轉介眼科醫師', '追蹤中若發現視力異常或需要藥物評估（如低濃度阿托品），依《驗光人員法》協助轉介眼科醫師，分工合作而非各自為政'],
        ].map(([title, desc]) => (
          <div class="border-t border-white/10 pt-5">
            <p class="font-sans text-brand-gold font-semibold mb-2" style="font-size:15px">{title}</p>
            <p class="text-white/60" style="font-size:14px;line-height:1.7">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 聚落文章 -->
  <section class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-10" style="font-size:clamp(24px,3.5vw,36px);font-weight:400">深入閱讀：兒童近視主題文章</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {clusterPosts.map(post => (
          <a href={`/blog/${post.slug}/`} class="bg-white rounded-2xl p-7 border border-brand-ink/5 hover:border-brand-gold transition-colors group">
            <span class="bg-brand-light text-brand-navy text-xs font-semibold px-3 py-1 rounded-full">{post.data.tag}</span>
            <h3 class="font-serif text-brand-navy mt-4 mb-3 group-hover:text-brand-gold transition-colors" style="font-size:18px;font-weight:600;line-height:1.5">{post.data.title}</h3>
            <p class="text-brand-ink-3 line-clamp-2" style="font-size:14px;line-height:1.7">{post.data.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="px-6 md:px-16 py-20 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-10" style="font-size:clamp(24px,3.5vw,36px);font-weight:400">常見問題</h2>
      <div class="space-y-8">
        {faqs.map(f => (
          <div class="border-b border-brand-ink/8 pb-8">
            <h3 class="font-serif text-brand-navy mb-3" style="font-size:18px;font-weight:600">Q：{f.q}</h3>
            <p class="text-brand-ink-2" style="font-size:16px;line-height:1.85">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 py-20" style="background:#1a2f4e">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-white mb-4" style="font-size:clamp(24px,3.5vw,34px);font-weight:300">與其焦慮，不如先掌握孩子的度數趨勢</h2>
      <p class="text-white/60 mb-8" style="font-size:16px;line-height:1.8">預約一次完整的兒童視覺評估，到店後會先由驗光人員建立孩子的度數與眼軸基準資料，再討論適合的配鏡與追蹤方案。新莊店 02-2206-6700（新莊區中正路419-1號）、板橋店 02-2253-1246。</p>
      <a href="/booking" class="inline-block bg-brand-gold text-brand-navy font-bold px-8 py-3.5 rounded-full hover:bg-brand-gold/90 transition-colors font-sans" style="font-size:15px">預約兒童視覺評估 →</a>
    </div>
  </section>

  <!-- 延伸閱讀：指南聚落互連（法務 🟢 純導覽） -->
  <section class="px-6 md:px-16 py-14 border-t border-brand-ink/10" style="background:#eee8da">
    <div class="max-w-5xl mx-auto">
      <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-6" style="font-size:12px;letter-spacing:0.18em">延伸閱讀｜其他完整指南</span>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { href: '/guide/high-myopia/', t: '高度近視配鏡完整指南' },
          { href: '/guide/choose-optician/', t: '新北配眼鏡完整指南' },
          { href: '/guide/optical-basics/', t: '視光小百科' },
        ].map(g => (
          <a href={g.href} class="block bg-brand-paper border border-brand-ink/10 px-5 py-4 hover:border-brand-gold transition-colors font-serif text-brand-navy" style="font-size:16px;font-weight:400">{g.t} →</a>
        ))}
      </div>
      <a href="/guide/" class="inline-block mt-6 font-sans text-brand-gold hover:text-brand-navy transition-colors" style="font-size:14px">← 回完整指南總覽</a>
    </div>
  </section>

</Layout>
