    <div class="max-w-5xl mx-auto">
      <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-6" style="font-size:12px;letter-spacing:0.18em">延伸閱讀｜其他完整指南</span>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { href: '/guide/optical-basics/', t: '視光小百科' },
          { href: '/guide/lens-brands/', t: '鏡片品牌選購完整指南' },
