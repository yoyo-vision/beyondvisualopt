---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 本指南的主題聚落文章（依閱讀順序排列）——英文版取 blog-en 集合
const CLUSTER_SLUGS = [
  'frame-face-shape',
  'frame-material-guide',
  'frame-fit-size',
  'frame-adjustment-handcraft',
  'minamoto-eyewear-brand',
];
const allPosts = await getCollection('blog-en');
const clusterPosts = CLUSTER_SLUGS
  .map(slug => allPosts.find(p => p.slug === slug))
  .filter(Boolean);

const canonicalUrl = 'https://beyondvisualopt.com/en/guide/frames/';

// 指南頁 FAQ（與聚落文章互補，不重複）
const faqs = [
  {
    q: 'When choosing a frame, should I go for looks first or fit first?',
    a: 'Both, but the order matters: filter for "fit" first, then pick the "good-looking" ones from within the ones that fit. Fit means the frame width aligns with your face width, the bridge and nose pads sit snugly, and the frame height is tall enough for your lens needs (progressives in particular need enough height). However good-looking a frame is, if the size is wrong it will slip, pinch and misalign the optical centre, and end up in a drawer. In practice we first pick out a few frames that suit your face shape and lens needs, and then you choose the style you like from those.',
  },
  {
    q: 'Can I buy a frame online and take it to an optical shop for lenses?',
    a: 'Technically yes, but there are a few risks to know first: online frames don\'t let you check the real size or feel, and it\'s common to end up with one too big or too small; material and hinge quality vary, and a frame that warps later may not be adjustable; and high-power or progressive lenses have requirements on the frame\'s size, curve and height, so the wrong frame directly affects lens performance. We do accept customer-supplied frames for fitting, but we first check whether the frame suits your prescription and lens design, to avoid finding out it doesn\'t work only after the lenses are in.',
  },
  {
    q: 'How long does a good frame last?',
    a: 'It depends on material and care, but 2–5 years or more is usually no problem. Pure titanium and quality acetate are highly durable; the hinges and temples are the main wear points. The real time to replace often isn\'t that the frame broke, but that the prescription changed significantly, or the frame has deformed and can no longer be adjusted back to the correct wearing position. Regular free adjustments at the store (nose pads, temple tension, level alignment) noticeably extend a frame\'s lifespan and wearing comfort.',
  },
  {
    q: 'For high myopia or a progressive lens, what should I watch for when choosing a frame?',
    a: 'For high myopia (a strong prescription) we suggest a smaller frame with a short edge-to-edge width, which effectively reduces the lens edge thickness and weight; the frame centre distance (the frame\'s optical centre) should sit as close to your PD as possible to avoid a prism effect. Progressives are the opposite: they need "enough frame height" to hold the full far, intermediate and near zones — a frame that\'s too flat cuts off the near zone and leaves you unable to find the clear reading position. These should all be considered when choosing the frame, not discovered after the lenses are made. At the Xinzhuang and Banqiao stores, Optometrist YoYo can help you choose a frame based on your prescription and lens design.',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": canonicalUrl,
      "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
      "url": canonicalUrl,
      "headline": "Choosing Eyeglass Frames: A Complete Guide to Face Shape, Material, Sizing and Lens Needs",
      "description": "How do you choose a frame for your face shape? What\'s the difference between acetate, metal and titanium? How do you tell whether a frame size fits? From aesthetics to optics, Optometrist YoYo explains every key point in one page. Beyond Visual Optometry, Xinzhuang and Banqiao.",
      "image": "https://beyondvisualopt.com/og-image.jpg",
      "inLanguage": "en",
      "articleSection": "Complete Guide",
      "author": {
        "@type": "Person",
        "@id": "https://beyondvisualopt.com/author/yoyo/#person",
        "name": "Cheng Chia-Yu (YoYo)",
        "url": "https://beyondvisualopt.com/author/yoyo/"
      },
      "publisher": { "@id": "https://beyondvisualopt.com/#organization" }
    },
    {
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
  ],
};
---
<Layout
  title="Eyeglass Frames Guide | Beyond Visual Optometry"
  description="How do you choose an eyeglass frame for your face shape? What sets acetate, metal, titanium and TR90 apart? How do you tell whether a frame fits? From aesthetics to optics, Optometrist YoYo explains the keys in one page. Beyond Visual Optometry, Xinzhuang and Banqiao."
  lang="en"
  schema={schema}
>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-navy to-[#0f1e33] text-white py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-brand-gold font-sans font-semibold tracking-widest uppercase mb-5" style="font-size:13px;letter-spacing:0.2em">Complete Guide</p>
      <h1 class="font-serif text-white leading-tight mb-7" style="font-size:clamp(30px,4.5vw,52px);font-weight:300">
        Choosing Eyeglass Frames<br /><span class="text-brand-gold">Complete Guide</span>
      </h1>
      <p class="text-white/70 max-w-2xl mx-auto" style="font-size:18px;line-height:1.85">
        Face shape, material, sizing and fit — choosing a frame is about more than looks; it also decides whether your lenses can perform. Optometrist YoYo explains it from aesthetics to optics, all in one place.
      </p>
    </div>
  </section>

  <!-- TL;DR 3秒重點（GEO：answer-first） -->
  <section class="px-6 md:px-16 py-10" style="background:#eee8da">
    <div class="max-w-4xl mx-auto">
      <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.2em">Quick Takeaways</span>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-3 text-brand-ink-2" style="font-size:16px;line-height:1.7"><span class="text-brand-gold mt-1 shrink-0">✦</span><span>The order of choosing: filter for "fit" first (width aligned to your face, nose pads snug, height enough for your lens needs), then pick the "good-looking" ones from among those that fit.</span></li>
        <li class="flex items-start gap-3 text-brand-ink-2" style="font-size:16px;line-height:1.7"><span class="text-brand-gold mt-1 shrink-0">✦</span><span>Matching a frame to a face usually works better by "contrast" than by "similarity": a round face suits an angular frame to sharpen the outline, a square face suits a rounder frame to soften the lines.</span></li>
        <li class="flex items-start gap-3 text-brand-ink-2" style="font-size:16px;line-height:1.7"><span class="text-brand-gold mt-1 shrink-0">✦</span><span>Material decides weight, adjustability and allergy risk: acetate has design appeal, pure titanium is light and low-allergy, metal is sleek and affordable, TR90 is impact-resistant and flexible.</span></li>
        <li class="flex items-start gap-3 text-brand-ink-2" style="font-size:16px;line-height:1.7"><span class="text-brand-gold mt-1 shrink-0">✦</span><span>A frame is a carrier for the lens: high myopia needs a small frame, progressives need enough frame height, and personalized custom lenses need the frame curve and pantoscopic tilt confirmed first.</span></li>
      </ul>
    </div>
  </section>

  <!-- 快速導覽 -->
  <section class="px-6 py-10 border-b border-brand-ink/8" style="background:#f7f3ec">
    <div class="max-w-4xl mx-auto flex flex-wrap gap-3 justify-center">
      {[
        { label: 'Face Shape and Frames', href: '#shape' },
        { label: 'Material Comparison', href: '#material' },
        { label: 'Sizing and Fit', href: '#fit' },
        { label: 'Frame Must Serve the Lens', href: '#lens' },
        { label: 'Read More', href: '#cluster' },
        { label: 'FAQ', href: '#faq' },
      ].map(item => (
        <a href={item.href} class="font-sans bg-white border border-brand-ink/10 text-brand-ink-2 px-4 py-2 rounded-full hover:border-brand-gold hover:text-brand-gold transition-colors" style="font-size:13px">{item.label}</a>
      ))}
    </div>
  </section>

  <!-- 臉型 -->
  <section id="shape" class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-4" style="font-size:clamp(24px,3.5vw,36px);font-weight:400">Matching a frame to your face: the contrast principle</h2>
      <p class="text-brand-ink-3 mb-10" style="font-size:16px;line-height:1.8">The core idea in one line: <strong>a frame's lines usually look better "contrasting" with your face shape than "matching" it.</strong> A rounder face suits a slightly angular frame to sharpen the outline; a squarer face suits a rounder frame to soften the lines.</p>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse" style="font-size:15px">
          <thead>
            <tr class="bg-brand-navy text-white">
              <th class="text-left px-5 py-4 font-semibold">Face shape</th>
              <th class="text-left px-5 py-4 font-semibold">Recommended frames</th>
              <th class="text-left px-5 py-4 font-semibold">Avoid</th>
            </tr>
          </thead>
          <tbody class="text-brand-ink-2">
            {[
              ['Round', 'Square, Wellington, angular frames — draw out the outline', 'Small round frames (reinforce roundness)'],
              ['Square', 'Round, oval, thin metal frames — soften the jawline', 'Heavy square frames (reinforce angles)'],
              ['Long', 'Taller frames, decorated temples — visually shorten the face', 'Overly flat narrow frames'],
              ['Heart (wide forehead, pointed chin)', 'Frames wider at the bottom, rimless/thin frames — balance top and bottom', 'Thick frames heavy along the top edge'],
              ['Oval', 'Most frame shapes suit; choose by facial proportion', 'Frames too large or too small that throw off balance'],
            ].map(row => (
              <tr class="border-b border-brand-ink/8">
                {row.map((cell, i) => (
                  <td class={`px-5 py-4 align-top ${i === 0 ? 'font-semibold text-brand-navy whitespace-nowrap' : ''}`}>{cell}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-brand-ink-2 mt-8" style="font-size:16px;line-height:1.8">
        Full face-shape selection principles: <a href="/en/blog/frame-face-shape/" class="text-brand-gold underline">How to choose an eyeglass frame for your face shape: round, square and oval faces</a>
      </p>
    </div>
  </section>

  <!-- 材質 -->
  <section id="material" class="px-6 md:px-16 py-20 bg-white">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-4" style="font-size:clamp(24px,3.5vw,36px);font-weight:400">How to choose material: the trade-offs of weight, durability and allergy</h2>
      <p class="text-brand-ink-3 mb-10" style="font-size:16px;line-height:1.8">Material decides weight, adjustability and allergy risk — for people who wear glasses long hours, this affects the experience more than looks.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { name: 'Acetate', desc: 'Rich colour and texture, fine feel, adjustable curve — the mainstream for design pieces. Medium weight, with presence in thicker frames.', tag: 'Design Appeal' },
          { name: 'Pure Titanium / β-Titanium', desc: 'Extremely light, corrosion-resistant, low-allergy — suited to long wear and strong prescriptions (heavy lenses). Higher price, the top choice for the high end.', tag: 'Light · Low-Allergy' },
          { name: 'Metal (stainless steel / Monel)', desc: 'Fine and sleek, affordable, malleable and easy to adjust. Some contain nickel, so sensitive skin should take note.', tag: 'Sleek' },
          { name: 'TR90 Plastic-Steel', desc: 'Light, flexible, impact-resistant — good for sport and children. Less adjustable, with a more casual feel.', tag: 'Durable · Flexible' },
        ].map(item => (
          <div class="bg-brand-paper rounded-2xl p-7 border border-brand-ink/5">
            <span class="font-sans text-brand-gold font-semibold tracking-widest uppercase mb-3 block" style="font-size:11px;letter-spacing:0.16em">{item.tag}</span>
            <h3 class="font-serif text-brand-navy mb-3" style="font-size:18px;font-weight:600">{item.name}</h3>
            <p class="text-brand-ink-3" style="font-size:15px;line-height:1.75">{item.desc}</p>
          </div>
        ))}
      </div>
      <p class="text-brand-ink-2 mt-8" style="font-size:16px;line-height:1.8">
        Full material comparison table: <a href="/en/blog/frame-material-guide/" class="text-brand-gold underline">How to choose eyeglass frame material? A full comparison of acetate, metal, titanium and TR90</a>
      </p>
    </div>
  </section>

  <!-- 尺寸配適 -->
  <section id="fit" class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-8" style="font-size:clamp(24px,3.5vw,36px);font-weight:400">Sizing and fit: slipping and pinching are both size problems</h2>
      <div class="space-y-5 text-brand-ink-2" style="font-size:17px;line-height:1.85">
        <p>You'll often see a set of numbers on the inside of the temple, for example <strong>52□18-140</strong>: lens width 52 mm, bridge width 18 mm, temple length 140 mm. Understanding it keeps you from mistakes when buying online or changing frames.</p>
        <p><strong>Three tests of fit:</strong> the total frame width aligns with your face width without extending past the temples; the bridge or nose pads sit stably and snugly, neither pressing nor slipping; the temple length curves naturally behind the ear, neither pinching nor loose.</p>
        <p>And frame fit isn't just about comfort — a crooked frame or the wrong size shifts the lens's optical centre away from your pupils, directly affecting clarity, which is especially pronounced with progressives and strong prescriptions.</p>
      </div>
      <p class="text-brand-ink-2 mt-8" style="font-size:16px;line-height:1.8">
        Read the size markings and fit principles: <a href="/en/blog/frame-fit-size/" class="text-brand-gold underline">Glasses slipping or pinching? A full breakdown of frame sizing and fit</a>
      </p>
    </div>
  </section>

  <!-- 鏡框配合鏡片（深藍重點） -->
  <section id="lens" class="px-6 md:px-16 py-20" style="background:#1a2f4e">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-white mb-4" style="font-size:clamp(24px,3.5vw,36px);font-weight:300">The hidden key to choosing a frame: the frame serves the lens</h2>
      <p class="text-white/60 mb-10" style="font-size:16px;line-height:1.8">This is something an optical shop won't necessarily tell you, but an optometrist always thinks of first — the frame isn't just an accessory, it's the carrier for the lens.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-6">
        {[
          ['High myopia needs a small frame', 'The shorter the frame is edge-to-edge, the thinner and lighter the lens edge; a frame centre distance close to your PD reduces the prism effect', '/en/guide/high-myopia/'],
          ['Progressives need enough height', 'Insufficient frame height cuts off the near zone, leaving you unable to find the clear reading position', '/en/guide/progressive-lens/'],
          ['Frame curve affects custom lenses', 'Personalized custom lenses factor in the frame\'s pantoscopic tilt and curve, so these must be confirmed when choosing the frame', '/en/guide/lens-brands/'],
          ['Fit precision affects the optical centre', 'Only with the frame sitting straight and the nose pads and temples adjusted does the lens\'s optical centre land in the correct position over the pupils', '/en/blog/frame-adjustment-handcraft/'],
        ].map(([title, desc, href]) => (
          <a href={href} class="border-t border-white/10 pt-5 block group">
            <p class="font-sans text-brand-gold font-semibold mb-2 group-hover:underline" style="font-size:15px">{title} →</p>
            <p class="text-white/60" style="font-size:14px;line-height:1.7">{desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 聚落文章 -->
  <section id="cluster" class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-10" style="font-size:clamp(24px,3.5vw,36px);font-weight:400">Read more: articles on frames</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {clusterPosts.map(post => (
          <a href={`/en/blog/${post.slug}/`} class="bg-white rounded-2xl p-7 border border-brand-ink/5 hover:border-brand-gold transition-colors group">
            <span class="bg-brand-light text-brand-navy text-xs font-semibold px-3 py-1 rounded-full">{post.data.tag}</span>
            <h3 class="font-serif text-brand-navy mt-4 mb-3 group-hover:text-brand-gold transition-colors" style="font-size:18px;font-weight:600;line-height:1.5">{post.data.title}</h3>
            <p class="text-brand-ink-3 line-clamp-2" style="font-size:14px;line-height:1.7">{post.data.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="px-6 md:px-16 py-20 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-10" style="font-size:clamp(24px,3.5vw,36px);font-weight:400">Frequently Asked Questions</h2>
      <div class="space-y-8">
        {faqs.map(f => (
          <div class="border-b border-brand-ink/8 pb-8">
            <h3 class="font-serif text-brand-navy mb-3" style="font-size:18px;font-weight:600">Q: {f.q}</h3>
            <p class="text-brand-ink-2" style="font-size:16px;line-height:1.85">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 py-20" style="background:#1a2f4e">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-white mb-4" style="font-size:clamp(24px,3.5vw,34px);font-weight:300">Choosing a frame? Come and try them on in store</h2>
      <p class="text-white/60 mb-8" style="font-size:16px;line-height:1.8">Whether a frame fits is most accurate once it's on your face. At both the Xinzhuang and Banqiao stores, Optometrist YoYo helps you choose based on your face shape, prescription and lens needs — not pushing the most expensive one on you, but finding the pair most suited to you.</p>
      <a href="/en/booking" class="inline-block bg-brand-gold text-brand-navy font-bold px-8 py-3.5 rounded-full hover:bg-brand-gold/90 transition-colors font-sans" style="font-size:15px">Book an In-Store Fitting →</a>
    </div>
  </section>

  <!-- 延伸閱讀：指南聚落互連（法務 🟢 純導覽） -->
  <section class="px-6 md:px-16 py-14 border-t border-brand-ink/10" style="background:#eee8da">
    <div class="max-w-5xl mx-auto">
      <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-6" style="font-size:12px;letter-spacing:0.18em">Read More | Other Complete Guides</span>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { href: '/en/guide/high-myopia/', t: 'High Myopia Fitting Complete Guide' },
          { href: '/en/guide/optical-basics/', t: 'Optical Terms Explained' },
          { href: '/en/guide/choose-optician/', t: 'Getting Glasses in New Taipei Guide' },
        ].map(g => (
          <a href={g.href} class="block bg-brand-paper border border-brand-ink/10 px-5 py-4 hover:border-brand-gold transition-colors font-serif text-brand-navy" style="font-size:16px;font-weight:400">{g.t} →</a>
        ))}
      </div>
      <a href="/en/guide/" class="inline-block mt-6 font-sans text-brand-gold hover:text-brand-navy transition-colors" style="font-size:14px">← Back to all complete guides</a>
    </div>
  </section>

</Layout>
