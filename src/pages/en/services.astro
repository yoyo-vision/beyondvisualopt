---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Services | Beyond Visual Optometry | Xinzhuang & Banqiao, New Taipei"
  description="Complete clinical eye exams, ZEISS progressive lenses, children's myopia management, high myopia precision glasses, and digital eye strain solutions."
  lang="en"
  enPath="/en/services"
>
  <section class="bg-brand-navy text-white py-20 px-6 text-center">
    <h1 class="font-serif text-white mb-4" style="font-size:clamp(28px,5vw,48px);font-weight:300">Our Services</h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto font-sans">Clinical-grade eye care tailored to your vision needs.</p>
  </section>

  <section class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-8">
      {[
        {
          icon: '🔬',
          title: 'Complete Clinical Eye Exam',
          duration: 'First visit: 45–60 min',
          items: [
            'Subjective & objective refraction',
            'Binocular vision assessment',
            'Vertex distance measurement',
            'Accommodation & convergence testing',
            'Prescription report provided',
          ],
        },
        {
          icon: '👓',
          title: 'Progressive Lens Fitting',
          duration: 'First visit: 60 min',
          items: [
            'ZEISS Individual² personalized lenses',
            'Pantoscopic tilt correction',
            'Monocular PD measurement',
            'Pupil height measurement',
            'Adaptation follow-up included',
          ],
        },
        {
          icon: '👁️',
          title: "Children's Myopia Management",
          duration: 'First visit: approx. 60 min',
          items: [
            'Axial length baseline measurement',
            'MiSight defocus daily contact lens evaluation',
            'Defocus design lens fitting assessment',
            'Prescription & axial length tracking every 3–6 months',
          ],
        },
        {
          icon: '🔭',
          title: 'High Myopia Precision Glasses',
          duration: '45–60 min',
          items: [
            'Vertex distance correction for -6.00D and above',
            '1.74 ultra-thin lens selection',
            'Frame size optimization to minimize thickness',
            'Optical center precision alignment',
          ],
        },
        {
          icon: '💻',
          title: 'Digital Eye Strain Solution',
          duration: '45 min',
          items: [
            'ZEISS Digital Lens evaluation',
            'Screen distance assessment',
            'Anti-fatigue lens recommendation',
            'Blue light protection options',
          ],
        },
        {
          icon: '🔵',
          title: 'RGP Hard Contact Lens Fitting',
          duration: 'First visit: 60–90 min',
          items: [
            'Corneal topography assessment',
            'RGP trial lens fitting',
            'Wearing schedule guidance',
            'Follow-up care',
          ],
        },
      ].map(service => (
        <div class="bg-white border border-brand-ink/10 p-8">
          <div class="flex items-start gap-4 mb-6">
            <span style="font-size:28px">{service.icon}</span>
            <div>
              <h2 class="font-serif text-brand-ink mb-1" style="font-size:20px;font-weight:400">{service.title}</h2>
              <p class="font-sans text-brand-gold text-xs" style="letter-spacing:0.1em">{service.duration}</p>
            </div>
          </div>
          <ul class="space-y-2">
            {service.items.map(item => (
              <li class="font-sans text-sm text-brand-ink-2 flex gap-2">
                <span class="text-brand-gold mt-0.5">—</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="px-6 md:px-16 py-16" style="background:#eee8da">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-10 text-center" style="font-size:28px;font-weight:300">Frequently Asked Questions</h2>
      <div class="space-y-6">
        {[
          { q: 'Do I need an appointment?', a: 'Yes, we recommend booking in advance for a complete clinical eye exam. Walk-ins may be accommodated for simple adjustments or inquiries.' },
          { q: 'How long does a full eye exam take?', a: 'A complete clinical exam takes 45–60 minutes for first-time visitors. We do not rush — every parameter is carefully assessed to ensure your glasses are truly comfortable.' },
          { q: 'Can you help if my current glasses make me dizzy?', a: 'Yes. Dizziness from glasses is often caused by prescription errors, axis deviation, or incorrect frame adjustment. We provide a full binocular vision assessment to identify the root cause.' },
          { q: 'Do you speak English?', a: 'Basic English communication is available. We can assist foreign customers with prescription reading, lens selection, and basic consultations.' },
        ].map(faq => (
          <div class="border-b border-brand-ink/10 pb-6">
            <h3 class="font-sans font-semibold text-brand-ink mb-2" style="font-size:15px">{faq.q}</h3>
            <p class="font-sans text-brand-ink-2 text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Clinical photos -->
  <section class="px-6 md:px-16 py-16" style="background:#f7f3ec">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-serif text-brand-ink mb-10 text-center" style="font-size:26px;font-weight:300">Our Equipment</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <picture>
          <source srcset="/images/yoyo-examination.webp" type="image/webp" />
          <img src="/images/yoyo-examination.webp" alt="YoYo conducting a full clinical eye examination" width="800" height="500" class="w-full h-56 object-cover object-top" loading="lazy" />
        </picture>
        <picture>
          <source srcset="/images/instrument-corneal-map.webp" type="image/webp" />
          <img src="/images/instrument-corneal-map.webp" alt="NIDEK CA-800 Corneal Topographer" width="400" height="240" class="w-full h-56 object-cover" loading="lazy" />
        </picture>
        <picture>
          <source srcset="/images/instrument-phoropter.webp" type="image/webp" />
          <img src="/images/instrument-phoropter.webp" alt="TOPCON Phoropter" width="400" height="240" class="w-full h-56 object-cover" loading="lazy" />
        </picture>
      </div>
      <div class="grid md:grid-cols-3 gap-4 mt-4">
        <p class="font-sans text-xs text-brand-ink-3 text-center pt-2">YoYo — Full Clinical Exam</p>
        <p class="font-sans text-xs text-brand-ink-3 text-center pt-2">NIDEK CA-800 Corneal Topographer</p>
        <p class="font-sans text-xs text-brand-ink-3 text-center pt-2">TOPCON Integrated Phoropter</p>
      </div>
    </div>
  </section>

  <section class="py-12 text-center" style="background:#eee8da">
    <a href="/en/booking" class="font-sans bg-brand-navy text-white px-10 py-4 hover:bg-brand-navy/90 transition-colors" style="font-size:14px;letter-spacing:0.1em">Book an Exam</a>
  </section>
</Layout>
