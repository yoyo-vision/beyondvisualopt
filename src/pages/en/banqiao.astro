---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Banqiao Optometrist | Beyond Visual Optometry × Neng Jian Du Optometry Clinic"
  description="30+ years of clinical eye care in Banqiao, New Taipei. ZEISS certified dealer. 5-min walk from Jiangzicui MRT Station. Tel: 02-2253-1246."
  lang="en"
  enPath="/en/banqiao"
>
  <section class="bg-brand-navy text-white py-20 px-6 text-center">
    <p class="font-sans text-brand-gold mb-4" style="font-size:12px;letter-spacing:0.2em">BANQIAO LOCATION</p>
    <h1 class="font-serif text-white mb-4" style="font-size:clamp(26px,4vw,44px);font-weight:300">Beyond Visual Optometry<br />× Neng Jian Du Optometry Clinic</h1>
    <p class="text-white/70 font-sans">No. 28, Ln. 47, Sec. 2, Shuangshi Rd., Banqiao Dist., New Taipei City</p>
  </section>

  <!-- Store photo -->
  <div class="w-full overflow-hidden" style="max-height:380px">
    <picture>
      <source srcset="/images/store-banqiao.webp" type="image/webp" />
      <img src="/images/store-banqiao.webp" alt="Beyond Visual Optometry Banqiao store" width="1200" height="600" class="w-full object-cover" style="filter:sepia(6%);max-height:380px;object-position:center" loading="lazy" />
    </picture>
  </div>

  <section class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12">
      <div>
        <h2 class="font-serif text-brand-ink mb-8" style="font-size:26px;font-weight:300">Location Info</h2>
        <div class="space-y-4 font-sans text-sm text-brand-ink-2">
          <div class="flex gap-3"><span>📍</span><span>No. 28, Ln. 47, Sec. 2, Shuangshi Rd., Banqiao Dist., New Taipei City</span></div>
          <div class="flex gap-3"><span>📞</span><a href="tel:0222531246" class="hover:text-brand-navy">02-2253-1246</a></div>
          <div class="flex gap-3"><span>🚇</span><span>5-min walk from Jiangzicui MRT Station (Bannan Line)</span></div>
        </div>

        <h3 class="font-serif text-brand-ink mt-10 mb-4" style="font-size:20px;font-weight:300">Business Hours</h3>
        <table class="w-full font-sans text-sm text-brand-ink-2">
          <tbody>
            {[
              ['Monday – Sunday', '10:00 – 22:00'],
              ['2nd & 4th Sunday', 'Closed'],
            ].map(([day, hours]) => (
              <tr class="border-b border-brand-ink/8">
                <td class="py-2 pr-4 font-medium text-brand-ink">{day}</td>
                <td class="py-2">{hours}</td>
              </tr>
            ))}
          </tbody>
        </table>

        <div class="mt-8 space-y-3">
          <a href="tel:0222531246" class="block w-full text-center font-sans border border-brand-navy text-brand-navy py-3 hover:bg-brand-navy hover:text-white transition-colors" style="font-size:14px">
            Call: 02-2253-1246
          </a>
          <a href="https://lin.ee/SoWj9Ft" target="_blank" rel="noopener" class="block w-full text-center font-sans bg-[#06C755] text-white py-3 hover:opacity-90 transition-opacity" style="font-size:14px">
            Book via LINE
          </a>
        </div>
      </div>

      <div>
        <h2 class="font-serif text-brand-ink mb-8" style="font-size:26px;font-weight:300">Services Available</h2>
        <ul class="space-y-3 font-sans text-sm text-brand-ink-2">
          {[
            'Complete clinical vision exam',
            'ZEISS certified lens fitting (Individual², progressive)',
            'Progressive lens fitting & adaptation follow-up',
            'Senior vision & presbyopia solutions',
            'High myopia precision glasses',
            'Children\'s myopia tracking',
            'Digital eye strain solutions',
            'Frame adjustments',
            'Vision consultation',
          ].map(item => (
            <li class="flex gap-2"><span class="text-brand-gold">—</span><span>{item}</span></li>
          ))}
        </ul>

        <div class="mt-10 bg-brand-navy/5 border border-brand-ink/10 p-6">
          <p class="font-sans text-brand-gold text-xs mb-3" style="letter-spacing:0.15em">CLINIC LICENSE</p>
          <p class="font-sans text-brand-ink text-sm">Neng Jian Du Optometry Clinic<br />License No. 5Y31010039</p>
          <p class="font-sans text-brand-gold text-xs mt-4 mb-1" style="letter-spacing:0.15em">ESTABLISHED</p>
          <p class="font-sans text-brand-ink text-sm">1992 — Over 30 years serving Banqiao</p>
          <p class="font-sans text-brand-gold text-xs mt-4 mb-1" style="letter-spacing:0.15em">GOOGLE RATING</p>
          <p class="font-sans text-brand-ink text-sm">⭐ 5.0 / 5.0 (47 reviews)</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
