---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 英文版文章皆由 YoYo 驗光師撰寫，依日期新到舊排列
const posts = (await getCollection('blog-en')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { timeZone: 'Asia/Taipei', year: 'numeric', month: 'short', day: 'numeric' });

// 精簡經歷 timeline（E-E-A-T Expertise，老闆提供之真實資歷；醫療行為相關經歷一律標「過往資歷」，避免暗示為本店服務）
const career = [
  { year: '2020', role: 'National-certified licensed optometrist (License No. 003309)' },
  { year: '2020–2021', role: 'Tri-Service General Hospital, Ophthalmology Clinical Optometry Team (prior clinical experience)' },
  { year: '2022–2023', role: 'Director, Enrui Asia-Pacific Optometry Clinic' },
  { year: '2024', role: 'Lecturer, New Taipei City Optometrists Association · Advisor, New Taipei City Optometric Technicians Association' },
  { year: '2023–2026', role: 'Principal, Beyond Visual Optometry' },
];

// 去識別化服務對象（不具名，避個資法/姓名權；描述客群多元性作為 Experience 證明）
const servedGroups = 'from tech-industry engineers and business owners to professionals who use their eyes intensively for long hours; also including complex refractive needs, difficult binocular coordination, and post-refractive-surgery vision changes that call for careful fitting. Where eye-health assessment is involved, follow-up is co-managed with an ophthalmologist.';

// Person schema：E-E-A-T 核心 — 持照專業人士身份，供 Google 與 AI 搜尋引擎驗證作者資格
const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://beyondvisualopt.com/en/author/yoyo/#person",
  "name": "Cheng Chia-Yu (YoYo)",
  "alternateName": ["YoYo", "Optometrist YoYo"],
  "jobTitle": "Optometrist",
  "identifier": "License No. 003309",
  "url": "https://beyondvisualopt.com/en/author/yoyo/",
  "image": "https://beyondvisualopt.com/images/yoyo-optometrist.webp",
  "description": "Taiwan-licensed optometrist (License No. 003309), lead optometrist at Beyond Visual Optometry × BiYang Optometry Clinic. Specializing in clinical eye exams, binocular vision assessment, progressive lens fitting, children's myopia tracking, and RGP hard contact lens fitting.",
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "credentialCategory": "license",
    "name": "Republic of China (Taiwan) Optometrist License",
    "identifier": "License No. 003309"
  },
  "alumniOf": {
    "@type": "CollegeOrUniversity",
    "name": "Yuanpei University of Medical Technology"
  },
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Optometrist",
    "occupationalCategory": "Healthcare professional / optometry personnel (under the Taiwan Optometrists Act)"
  },
  "knowsAbout": [
    "clinical eye exams", "binocular vision assessment", "progressive lens fitting", "children's myopia tracking",
    "high myopia precision fitting", "vertex distance measurement", "pantoscopic tilt correction", "RGP hard contact lens fitting", "ZEISS lenses", "corneal topography and wavefront aberration analysis"
  ],
  "worksFor": { "@id": "https://beyondvisualopt.com/#organization" },
  "workLocation": [
    { "@id": "https://beyondvisualopt.com/#xinzhuang" },
    { "@id": "https://beyondvisualopt.com/#banqiao" }
  ],
  "sameAs": [
    "https://www.instagram.com/youzi_yu/",
    "https://www.instagram.com/bv_optical/",
    "https://www.threads.com/@youzi_yu",
    "https://vocus.cc/salon/bv_optical"
  ]
};
---
<Layout
  title="Optometrist YoYo (Cheng Chia-Yu) | License No. 003309 | Lead Optometrist at Beyond Visual Optometry"
  description="Cheng Chia-Yu (YoYo), Taiwan-licensed optometrist (License No. 003309), lead optometrist at Beyond Visual Optometry × BiYang Optometry Clinic. Specializing in clinical eye exams, binocular vision assessment, progressive lens fitting, and children's myopia tracking in Xinzhuang & Banqiao."
  lang="en"
  schema={schema}
>

  <!-- Hero：作者介紹 -->
  <section class="bg-gradient-to-br from-brand-navy to-[#0f1e33] text-white py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-12 items-center md:items-start">
        <img src="/images/yoyo-optometrist.webp" alt="Optometrist YoYo, Cheng Chia-Yu, Beyond Visual Optometry BiYang Optometry Clinic Xinzhuang"
          width="256" height="320" class="w-64 h-80 object-cover flex-shrink-0 rounded-2xl" />
        <div class="text-center md:text-left">
          <p class="text-brand-gold font-sans font-semibold tracking-widest uppercase mb-4" style="font-size:13px;letter-spacing:0.2em">About the Author</p>
          <h1 class="font-serif text-white leading-tight mb-3" style="font-size:clamp(30px,4.5vw,48px);font-weight:300">Optometrist Cheng Chia-Yu</h1>
          <p class="text-brand-gold font-sans mb-6" style="font-size:16px">YoYo | Lead Optometrist | License No. 003309</p>
          <div class="space-y-4 text-white/70" style="font-size:17px;line-height:1.85">
            <p>A graduate of Yuanpei University of Medical Technology and a national-certified licensed optometrist (License No. 003309), YoYo is a lecturer for the New Taipei City Optometrists Association and an advisor to the New Taipei City Optometric Technicians Association. As the lead optometrist at Beyond Visual Optometry × BiYang Optometry Clinic (Xinzhuang), YoYo specializes in clinical eye exams, binocular vision assessment, progressive lens fitting, children's myopia tracking, and RGP hard contact lens fitting, working at an authorized ZEISS dealer.</p>
            <p>Beyond Visual Optometry was founded by the family in Banqiao in 1992 — a local eyewear store of more than 30 years that has served over ten thousand local customers. YoYo grew up in the family business, and after completing national optometrist training, took the lead independently, bringing a complete clinical eye-exam standard process into the BiYang Optometry Clinic in Xinzhuang.</p>
            <p>Every vision-health article on this site is written or reviewed by Optometrist YoYo, based on clinical optometry practice and optical principles, with no exaggerated claims. Where abnormal vision is found, or vision cannot be corrected to normal, we refer to an ophthalmologist in accordance with the Optometrists Act.</p>
          </div>
          <div class="flex flex-wrap gap-3 justify-center md:justify-start mt-7">
            <a href="https://www.instagram.com/youzi_yu/" target="_blank" rel="noopener noreferrer"
              class="font-sans border border-white/30 text-white/80 px-5 py-2 hover:border-brand-gold hover:text-brand-gold transition-colors" style="font-size:13px;letter-spacing:0.08em">
              Instagram @youzi_yu
            </a>
            <a href="/en/booking" class="font-sans bg-brand-gold text-brand-navy font-bold px-5 py-2 hover:bg-brand-gold/90 transition-colors" style="font-size:13px;letter-spacing:0.08em">
              Book with Optometrist YoYo →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 專業領域 -->
  <section class="px-6 md:px-16 py-20" style="background:#f7f3ec">
    <div class="max-w-5xl mx-auto">
      <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.22em">Areas of Expertise</span>
      <h2 class="font-serif text-brand-ink mb-10" style="font-size:clamp(26px,3.5vw,38px);font-weight:300">Clinical Optometry Specialties</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { title: 'Full Clinical Eye Exam', desc: 'A complete 45–60 minute process: subjective and objective refraction, binocular vision assessment, and vertex distance measurement, to find the real cause of vision issues.' },
          { title: 'Progressive Multifocal Lenses', desc: 'ZEISS Individual² custom fitting, precise pantoscopic tilt correction, and adaptation follow-up to reduce dizziness and adaptation failure.' },
          { title: "Children's Myopia Tracking", desc: 'Regular tracking of prescription changes every 3–6 months and defocus-lens fitting assessment, monitoring the myopia trend together with parents.' },
          { title: 'High Myopia Precision Fitting', desc: 'Vertex distance correction for -6.00D and above, and 1.74 ultra-thin lens selection, balancing visual quality and wearing comfort.' },
          { title: 'RGP Hard Contact Lenses', desc: 'Rigid contact lens fitting and regular follow-up, suited to high astigmatism and special corneal conditions.' },
          { title: 'Digital Eye Strain Solution', desc: 'Visual-stress analysis for long-hour screen workers, and evaluation of relief options such as ZEISS Digital Lens.' },
        ].map(item => (
          <div class="bg-white rounded-2xl p-7 border border-brand-ink/5">
            <h3 class="font-serif text-brand-navy mb-3" style="font-size:18px;font-weight:600">{item.title}</h3>
            <p class="text-brand-ink-3" style="font-size:15px;line-height:1.75">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 經歷 Timeline + 服務對象（E-E-A-T Experience／Expertise） -->
  <section class="px-6 md:px-16 py-20" style="background:#eee8da">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-14">
      <div>
        <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.22em">Clinical Background</span>
        <h2 class="font-serif text-brand-ink mb-8" style="font-size:clamp(24px,3.5vw,34px);font-weight:300">A Professional Path, Step by Step</h2>
        <ul class="space-y-5">
          {career.map(c => (
            <li class="flex gap-5">
              <span class="font-sans text-brand-gold flex-shrink-0 pt-0.5" style="font-size:13px;font-weight:600;letter-spacing:0.03em;min-width:82px">{c.year}</span>
              <span class="text-brand-ink-2 border-l-2 border-brand-gold/30 pl-5" style="font-size:15px;line-height:1.6">{c.role}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="md:pl-6">
        <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.22em">Who We Serve</span>
        <h2 class="font-serif text-brand-ink mb-6" style="font-size:clamp(24px,3.5vw,34px);font-weight:300">From Every Walk of Life<br />to the Difficult Cases</h2>
        <p class="text-brand-ink-2 mb-6" style="font-size:16px;line-height:1.9">
          Over years of clinical fitting, YoYo has served people across every profession — {servedGroups}
        </p>
        <p class="text-brand-ink-3" style="font-size:14px;line-height:1.8">
          Every viewing pattern and every hard-to-solve vision problem adds to the depth of fitting skill. That's why we believe an eye exam can't just measure a prescription — it has to understand how you use your eyes.
        </p>
      </div>
    </div>
  </section>

  <!-- 文章列表 -->
  <section class="px-6 md:px-16 py-20 bg-white">
    <div class="max-w-5xl mx-auto">
      <span class="font-sans text-brand-ink-3 tracking-widest uppercase block mb-4" style="font-size:12px;letter-spacing:0.22em">Vision Notes</span>
      <h2 class="font-serif text-brand-ink mb-10" style="font-size:clamp(26px,3.5vw,38px);font-weight:300">Articles by Optometrist YoYo ({posts.length})</h2>
      <ul class="divide-y divide-brand-ink/8">
        {posts.map(post => (
          <li>
            <a href={`/en/blog/${post.slug}/`} class="flex flex-col md:flex-row md:items-center gap-2 md:gap-6 py-5 group">
              <span class="font-sans text-brand-ink-3 flex-shrink-0 md:w-28" style="font-size:13px">{formatDate(post.data.date)}</span>
              <span class="bg-brand-light text-brand-navy text-xs font-semibold px-3 py-1 rounded-full flex-shrink-0 w-fit">{post.data.tag}</span>
              <span class="text-brand-ink group-hover:text-brand-gold transition-colors" style="font-size:16px;line-height:1.6">{post.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</Layout>
