    <div class="max-w-6xl mx-auto px-6 md:px-16">
      <div class="grid grid-cols-3 md:grid-cols-6 divide-x divide-brand-paper/10">
        {[
          { label: '關於我們', href: '/about' },
          { label: '服務項目', href: '/services' },
          { label: '鏡框品牌', href: '/frames' },
          { label: '鏡片種類', href: '/lenses' },
          { label: '視覺小知識', href: '/blog' },
          { label: '立即預約', href: '/booking' },
        ].map(item => (
          <a href={item.href}
            class="block text-center py-4 text-brand-paper/40 hover:text-brand-gold transition-colors font-sans"
            style="font-size:13px;letter-spacing:0.08em">
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

