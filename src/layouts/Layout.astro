---
export interface Props {
  title: string;
  description: string;
  keywords?: string;
  image?: string;
  schema?: object;
}
const { title, description, keywords, image = '/og-image.jpg', schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <meta name="author" content="鄭家侑（YoYo）・能見度眼鏡" />
  <meta name="publisher" content="能見度眼鏡 Beyond Visual Optometry" />
  <meta name="robots" content="index, follow" />
  <meta name="google-site-verification" content="b9R-zvmjM3wN6sH5QabENei5LBkcg4sKtx3zIv0Jijw" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:locale" content="zh_TW" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Google Analytics GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-B3DK67BENE"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-B3DK67BENE');
  </script>

  <!-- 字型：非阻斷式載入 -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=Noto+Serif+TC:wght@300;400;500;600&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=Noto+Serif+TC:wght@300;400;500;600&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=Noto+Serif+TC:wght@300;400;500;600&display=swap" /></noscript>

  <!-- LocalBusiness JSON-LD（每頁都嵌入） -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://beyondvisualopt.com/#organization",
        "name": "能見度眼鏡",
        "alternateName": "Beyond Visual Optometry",
        "url": "https://beyondvisualopt.com",
        "logo": "https://beyondvisualopt.com/images/logo.png",
        "email": "visibility.opticians@gmail.com",
        "description": "台灣新北市新莊、板橋專業驗光品牌。旗下含能見度視覺中心（新莊比泱驗光所）與能見度眼鏡（板橋能見度驗光所），提供蔡司鏡片、多焦點鏡片、兒童近視追蹤與高度近視配鏡服務。",
        "sameAs": [
          "https://www.instagram.com/bv_optical/",
          "https://www.instagram.com/youzi_yu/",
          "https://www.facebook.com/NengJianDuYanJingXing/"
        ],
        "employee": {
          "@type": "Person",
          "name": "鄭家侑",
          "alternateName": "YoYo",
          "jobTitle": "驗光師",
          "identifier": "驗師字第 003309 號"
        }
      },
      {
        "@type": "Optician",
        "@id": "https://beyondvisualopt.com/#xinzhuang",
        "name": "能見度視覺中心 × 比泱驗光所",
        "alternateName": ["比泱驗光所", "能見度視覺中心", "新莊驗光所"],
