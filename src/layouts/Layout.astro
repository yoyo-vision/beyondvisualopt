          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Saturday","Sunday"],
            "opens": "10:00",
            "closes": "18:00"
          }
        ],
        "sameAs": ["https://share.google/rMxJYqYZH6fR4QwrS"],
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5.0",
