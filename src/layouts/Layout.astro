  <title>{title}</title>
</head>
<body class="bg-brand-paper font-serif text-brand-ink antialiased" style="font-size:17px;line-height:1.75">
  <!-- 導覽列 -->
  <header class="sticky top-0 z-50 backdrop-blur-md border-b border-brand-ink/10" style="background:rgba(247,243,236,0.95)">
    <nav class="max-w-6xl mx-auto px-6 flex items-center justify-between h-[68px]">
      <a href="/" class="flex items-center gap-3">
        <img src="/images/logo.png" alt="能見度眼鏡 Logo" class="h-11 w-auto" />
        <div class="flex flex-col" style="gap:1px">
          <span class="font-serif text-brand-navy" style="font-size:17px;font-weight:600;letter-spacing:0.05em;line-height:1.1">能見度眼鏡</span>
          <span class="font-sans text-brand-gray" style="font-size:9px;font-weight:400;letter-spacing:0.18em;line-height:1">Beyond Visual</span>
        </div>
      </a>
      <!-- 桌機選單 -->
      <ul class="hidden md:flex items-center gap-8 font-sans" style="font-size:14px;letter-spacing:0.04em">
        <li><a href="/about" class="text-brand-ink-2 hover:text-brand-ink transition-colors">關於我們</a></li>
        <li><a href="/services" class="text-brand-ink-2 hover:text-brand-ink transition-colors">服務內容</a></li>
        <li><a href="/process" class="text-brand-ink-2 hover:text-brand-ink transition-colors">服務流程</a></li>
        <li><a href="/frames" class="text-brand-ink-2 hover:text-brand-ink transition-colors">鏡框品牌</a></li>
        <li><a href="/lenses" class="text-brand-ink-2 hover:text-brand-ink transition-colors">鏡片種類</a></li>
        <li><a href="/blog" class="text-brand-ink-2 hover:text-brand-ink transition-colors">視覺小知識</a></li>
      </ul>
      <div class="flex items-center gap-3">
        <a href="/booking"
          class="hidden md:inline-block font-sans border border-brand-ink text-brand-ink px-5 py-2 hover:bg-brand-ink hover:text-brand-paper transition-all duration-300"
          style="letter-spacing:0.1em;font-size:13px">
          立即預約
        </a>
        <!-- 手機漢堡按鈕 -->
        <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="開啟選單">
          <span class="block w-6 h-0.5 bg-brand-ink transition-all"></span>
          <span class="block w-6 h-0.5 bg-brand-ink transition-all"></span>
          <span class="block w-6 h-0.5 bg-brand-ink transition-all"></span>
        </button>
      </div>
    </nav>
    <!-- 手機下拉選單 -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-brand-ink/10" style="background:rgba(247,243,236,0.98)">
      <ul class="font-sans px-6 py-4 space-y-0">
        <li><a href="/about" class="block py-3.5 text-brand-ink-2 border-b border-brand-ink/8 hover:text-brand-ink" style="font-size:16px">關於我們</a></li>
        <li><a href="/services" class="block py-3.5 text-brand-ink-2 border-b border-brand-ink/8 hover:text-brand-ink" style="font-size:16px">服務內容</a></li>
        <li><a href="/process" class="block py-3.5 text-brand-ink-2 border-b border-brand-ink/8 hover:text-brand-ink" style="font-size:16px">服務流程</a></li>
        <li><a href="/frames" class="block py-3.5 text-brand-ink-2 border-b border-brand-ink/8 hover:text-brand-ink" style="font-size:16px">鏡框品牌</a></li>
        <li><a href="/lenses" class="block py-3.5 text-brand-ink-2 border-b border-brand-ink/8 hover:text-brand-ink" style="font-size:16px">鏡片種類</a></li>
        <li><a href="/blog" class="block py-3.5 text-brand-ink-2 border-b border-brand-ink/8 hover:text-brand-ink" style="font-size:16px">視覺小知識</a></li>
        <li><a href="/booking" class="block py-3.5 text-brand-navy font-semibold" style="font-size:16px">立即預約 →</a></li>
      </ul>
    </div>
  </header>
  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>

  <main>
    <slot />
  </main>

  <!-- 頁尾 -->
  <!-- 頁尾小導覽列 -->
