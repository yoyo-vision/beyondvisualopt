          "addressLocality": "新莊區",
          "addressRegion": "新北市",
          "postalCode": "242",
          "addressCountry": "TW"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 25.0338,
          "longitude": 121.4487
        },
        "hasCredential": "新北府莊衛驗光字第 5Y31060655 號",
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
