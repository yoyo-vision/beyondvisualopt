---
export interface Props {
  title: string;
  description: string;
  image?: string;
  schema?: object;
}
const { title, description, image = '/og-image.jpg', schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:locale" content="zh_TW" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- 字型 -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- LocalBusiness JSON-LD（每頁都嵌入） -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Optician",
    "name": "能見度視覺中心",
    "alternateName": "Beyond Visual Optometry",
    "url": "https://beyondvisualopt.com",
    "logo": "https://beyondvisualopt.com/logo.png",
    "description": "台灣新北市新莊、板橋專業驗光。多焦點鏡片、蔡司鏡片、兒童近視控制、高度近視眼鏡。YoYo 驗光師、能見度視覺中心、比泱驗光所。",
    "keywords": [
      "多焦點鏡片","蔡司鏡片","高度近視眼鏡","兒童近視控制","近視控制",
      "老花一定要配多焦點嗎","為什麼戴眼鏡會頭暈",
      "能見度視覺中心","比泱驗光所","YoYo 驗光師",
      "新莊驗光","板橋驗光","新莊眼鏡行推薦","板橋眼鏡行",
      "新北市驗光所","新莊配眼鏡","板橋配眼鏡","新莊驗光所推薦"
    ],
    "telephone": "+886-2-XXXX-XXXX",
    "email": "yoyo86421@gmail.com",
    "address": [
      {
        "@type": "PostalAddress",
        "streetAddress": "中正路",
        "addressLocality": "新莊區",
        "addressRegion": "新北市",
        "addressCountry": "TW"
      }
    ],
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 25.0338,
      "longitude": 121.4487
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "10:00",
        "closes": "20:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Saturday","Sunday"],
        "opens": "10:00",
        "closes": "18:00"
      }
    ],
    "sameAs": [
      "https://www.instagram.com/beyondvisualopt",
      "https://line.me/ti/p/beyondvisualopt"
    ]
  })} />

  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <title>{title}</title>
</head>
<body class="bg-white font-sans text-gray-800 antialiased">
  <!-- 導覽列 -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100 shadow-sm">
    <nav class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <span class="text-brand-navy font-bold text-xl tracking-tight">能見度視覺中心</span>
      </a>
      <!-- 桌機選單 -->
      <ul class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
        <li><a href="/services" class="hover:text-brand-navy transition-colors">服務內容</a></li>
        <li><a href="/process" class="hover:text-brand-navy transition-colors">服務流程</a></li>
        <li><a href="/frames" class="hover:text-brand-navy transition-colors">鏡框品牌</a></li>
        <li><a href="/lenses" class="hover:text-brand-navy transition-colors">鏡片種類</a></li>
        <li><a href="/blog" class="hover:text-brand-navy transition-colors">視覺小知識</a></li>
      </ul>
      <a href="/booking"
        class="bg-brand-navy text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-brand-navy/90 transition-colors">
        立即預約
      </a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <!-- 頁尾 -->
  <footer class="bg-brand-navy text-white mt-20">
    <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-bold text-lg mb-3">能見度視覺中心</h3>
        <p class="text-gray-300 text-sm leading-relaxed">不追求最貴，只追求最適合。<br />台灣高端臨床驗光與功能性眼鏡品牌。</p>
      </div>
      <div>
        <h3 class="font-bold text-lg mb-3">門市資訊</h3>
        <ul class="text-gray-300 text-sm space-y-1">
          <li>🏪 新莊店：新北市新莊區中正路</li>
          <li>🏪 板橋店：新北市板橋區</li>
          <li>📞 LINE OA 預約優先</li>
        </ul>
      </div>
      <div>
        <h3 class="font-bold text-lg mb-3">快速連結</h3>
        <ul class="text-gray-300 text-sm space-y-1">
          <li><a href="/services" class="hover:text-brand-gold transition-colors">服務內容</a></li>
          <li><a href="/blog" class="hover:text-brand-gold transition-colors">視覺小知識</a></li>
          <li><a href="/booking" class="hover:text-brand-gold transition-colors">線上預約</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10 text-center text-gray-400 text-xs py-4">
      © 2026 能見度視覺中心 Beyond Visual Optometry. All rights reserved.
    </div>
  </footer>
</body>
</html>
