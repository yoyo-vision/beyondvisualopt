---
export interface Props {
  title: string;
  description: string;
  image?: string;
  schema?: object;
}
const { title, description, image = '/og-image.jpg', schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="google-site-verification" content="b9R-zvmjM3wN6sH5QabENei5LBkcg4sKtx3zIv0Jijw" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:locale" content="zh_TW" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- 字型 -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- LocalBusiness JSON-LD（每頁都嵌入） -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Optician",
    "name": "能見度視覺中心",
    "alternateName": "Beyond Visual Optometry",
    "url": "https://beyondvisualopt.com",
    "logo": "https://beyondvisualopt.com/logo.png",
    "description": "台灣新北市新莊、板橋專業驗光。多焦點鏡片、蔡司鏡片、兒童近視控制、高度近視眼鏡。YoYo 驗光師、能見度視覺中心、比泱驗光所。",
    "keywords": [
      "多焦點鏡片","蔡司鏡片","高度近視眼鏡","兒童近視控制","近視控制",
      "老花一定要配多焦點嗎","為什麼戴眼鏡會頭暈",
      "能見度視覺中心","比泱驗光所","YoYo 驗光師",
      "新莊驗光","板橋驗光","新莊眼鏡行推薦","板橋眼鏡行",
      "新北市驗光所","新莊配眼鏡","板橋配眼鏡","新莊驗光所推薦"
    ],
    "telephone": "+886-2-2206-6700",
    "email": "visibility.opticians@gmail.com",
    "address": [
      {
        "@type": "PostalAddress",
        "streetAddress": "中正路419-1號",
        "addressLocality": "新莊區",
        "addressRegion": "新北市",
        "postalCode": "242",
        "addressCountry": "TW"
      },
      {
        "@type": "PostalAddress",
        "addressLocality": "板橋區",
        "addressRegion": "新北市",
        "addressCountry": "TW"
      }
    ],
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 25.0338,
      "longitude": 121.4487
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "10:00",
        "closes": "20:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Saturday","Sunday"],
        "opens": "10:00",
        "closes": "18:00"
      }
    ],
    "sameAs": [
      "https://www.instagram.com/bv_optical/",
      "https://www.instagram.com/youzi_yu/",
      "https://www.facebook.com/NengJianDuYanJingXing/",
      "https://share.google/rMxJYqYZH6fR4QwrS",
      "https://share.google/lReL1vW8OEUXZBeVy"
    ]
  })} />

  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <title>{title}</title>
</head>
<body class="bg-white font-sans text-gray-800 antialiased">
  <!-- 導覽列 -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100 shadow-sm">
    <nav class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <img src="/images/logo.png" alt="能見度視覺中心 Logo" class="h-10 w-auto" />
      </a>
      <!-- 桌機選單 -->
      <ul class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
        <li><a href="/services" class="hover:text-brand-navy transition-colors">服務內容</a></li>
        <li><a href="/process" class="hover:text-brand-navy transition-colors">服務流程</a></li>
        <li><a href="/frames" class="hover:text-brand-navy transition-colors">鏡框品牌</a></li>
        <li><a href="/lenses" class="hover:text-brand-navy transition-colors">鏡片種類</a></li>
        <li><a href="/blog" class="hover:text-brand-navy transition-colors">視覺小知識</a></li>
      </ul>
      <a href="/booking"
        class="bg-brand-navy text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-brand-navy/90 transition-colors">
        立即預約
      </a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <!-- 頁尾 -->
  <footer class="bg-brand-navy text-white mt-20">
    <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-bold text-lg mb-3">能見度視覺中心</h3>
        <p class="text-gray-300 text-sm leading-relaxed">不追求最貴，只追求最適合。<br />台灣高端臨床驗光與功能性眼鏡品牌。</p>
      </div>
      <div>
        <h3 class="font-bold text-lg mb-3">門市資訊</h3>
        <ul class="text-gray-300 text-sm space-y-1">
          <li>🏪 新莊店：新北市新莊區中正路419-1號</li>
          <li>📞 新莊店：02-2206-6700</li>
          <li>🏪 板橋總店：新北市板橋區雙十路二段47巷28號</li>
          <li>📞 板橋店：02-2253-1246</li>
          <li>✉️ visibility.opticians@gmail.com</li>
        </ul>
      </div>
      <div>
        <h3 class="font-bold text-lg mb-3">快速連結</h3>
        <ul class="text-gray-300 text-sm space-y-1">
          <li><a href="/services" class="hover:text-brand-gold transition-colors">服務內容</a></li>
          <li><a href="/blog" class="hover:text-brand-gold transition-colors">視覺小知識</a></li>
          <li><a href="/booking" class="hover:text-brand-gold transition-colors">線上預約</a></li>
        </ul>
        <h3 class="font-bold text-lg mt-6 mb-3">追蹤我們</h3>
        <div class="flex flex-col gap-2">
          <a href="https://www.instagram.com/bv_optical/" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 text-gray-300 text-sm hover:text-brand-gold transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            @bv_optical 門市 IG
          </a>
          <a href="https://www.instagram.com/youzi_yu/" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 text-gray-300 text-sm hover:text-brand-gold transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            @youzi_yu YoYo 驗光師
          </a>
          <a href="https://www.facebook.com/NengJianDuYanJingXing/" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 text-gray-300 text-sm hover:text-brand-gold transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook 粉絲頁
          </a>
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 text-center text-gray-400 text-xs py-4">
      © 2026 能見度視覺中心 Beyond Visual Optometry. All rights reserved.
    </div>
  </footer>
</body>
</html>
